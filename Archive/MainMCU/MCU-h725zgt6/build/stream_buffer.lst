 114:Core/Inc/portmacro.h **** /* Critical section management. */
 115:Core/Inc/portmacro.h **** extern void vPortEnterCritical( void );
 116:Core/Inc/portmacro.h **** extern void vPortExitCritical( void );
 117:Core/Inc/portmacro.h **** #define portSET_INTERRUPT_MASK_FROM_ISR()         ulPortRaiseBASEPRI()
 118:Core/Inc/portmacro.h **** #define portCLEAR_INTERRUPT_MASK_FROM_ISR( x )    vPortSetBASEPRI( x )
 119:Core/Inc/portmacro.h **** #define portDISABLE_INTERRUPTS()                  vPortRaiseBASEPRI()
 120:Core/Inc/portmacro.h **** #define portENABLE_INTERRUPTS()                   vPortSetBASEPRI( 0 )
 121:Core/Inc/portmacro.h **** #define portENTER_CRITICAL()                      vPortEnterCritical()
 122:Core/Inc/portmacro.h **** #define portEXIT_CRITICAL()                       vPortExitCritical()
