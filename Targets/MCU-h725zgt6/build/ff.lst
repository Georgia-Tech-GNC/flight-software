2841:../../Extensions/fatfs//src/ff.c **** 		obj->c_ofs = fs->cdc_ofs;
2842:../../Extensions/fatfs//src/ff.c **** 		res = load_obj_dir(&dj, obj);
2843:../../Extensions/fatfs//src/ff.c **** 		if (res != FR_OK) return res;
