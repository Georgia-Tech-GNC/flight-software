 273:../../Extensions/fatfs//src/ff.c **** /* Character code support macros */
 274:../../Extensions/fatfs//src/ff.c **** #define IsUpper(c)	(((c)>='A')&&((c)<='Z'))
 275:../../Extensions/fatfs//src/ff.c **** #define IsLower(c)	(((c)>='a')&&((c)<='z'))
 276:../../Extensions/fatfs//src/ff.c **** #define IsDigit(c)	(((c)>='0')&&((c)<='9'))
 277:../../Extensions/fatfs//src/ff.c **** 
 278:../../Extensions/fatfs//src/ff.c **** #if _DF1S != 0	/* Code page is DBCS */
 279:../../Extensions/fatfs//src/ff.c **** 
 280:../../Extensions/fatfs//src/ff.c **** #ifdef _DF2S	/* Two 1st byte areas */
 281:../../Extensions/fatfs//src/ff.c **** #define IsDBCS1(c)	(((BYTE)(c) >= _DF1S && (BYTE)(c) <= _DF1E) || ((BYTE)(c) >= _DF2S && (BYTE)(c) 
 282:../../Extensions/fatfs//src/ff.c **** #else			/* One 1st byte area */
 283:../../Extensions/fatfs//src/ff.c **** #define IsDBCS1(c)	((BYTE)(c) >= _DF1S && (BYTE)(c) <= _DF1E)
