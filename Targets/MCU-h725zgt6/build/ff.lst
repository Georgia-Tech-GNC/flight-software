3876:../../Extensions/fatfs//src/ff.c **** 	DEF_NAMBUF
3877:../../Extensions/fatfs//src/ff.c **** 
3878:../../Extensions/fatfs//src/ff.c **** 	/* Get logical drive */
3879:../../Extensions/fatfs//src/ff.c **** 	res = find_volume(&path, &fs, 0);
3880:../../Extensions/fatfs//src/ff.c **** 	if (res == FR_OK) {
3881:../../Extensions/fatfs//src/ff.c **** 		dj.obj.fs = fs;
3882:../../Extensions/fatfs//src/ff.c **** 		INIT_NAMBUF(fs);
3883:../../Extensions/fatfs//src/ff.c **** 		res = follow_path(&dj, path);		/* Follow the path */
3884:../../Extensions/fatfs//src/ff.c **** 		if (res == FR_OK) {					/* Follow completed */
3885:../../Extensions/fatfs//src/ff.c **** 			if (dj.fn[NSFLAG] & NS_NONAME) {
3886:../../Extensions/fatfs//src/ff.c **** 				fs->cdir = dj.obj.sclust;	/* It is the start directory itself */
3887:../../Extensions/fatfs//src/ff.c **** #if _FS_EXFAT
3888:../../Extensions/fatfs//src/ff.c **** 				if (fs->fs_type == FS_EXFAT) {
3889:../../Extensions/fatfs//src/ff.c **** 					fs->cdc_scl = dj.obj.c_scl;
3890:../../Extensions/fatfs//src/ff.c **** 					fs->cdc_size = dj.obj.c_size;
3891:../../Extensions/fatfs//src/ff.c **** 					fs->cdc_ofs = dj.obj.c_ofs;
3892:../../Extensions/fatfs//src/ff.c **** 				}
3893:../../Extensions/fatfs//src/ff.c **** #endif
3894:../../Extensions/fatfs//src/ff.c **** 			} else {
3895:../../Extensions/fatfs//src/ff.c **** 				if (dj.obj.attr & AM_DIR) {	/* It is a sub-directory */
3896:../../Extensions/fatfs//src/ff.c **** #if _FS_EXFAT
3897:../../Extensions/fatfs//src/ff.c **** 					if (fs->fs_type == FS_EXFAT) {
3898:../../Extensions/fatfs//src/ff.c **** 						fs->cdir = ld_dword(fs->dirbuf + XDIR_FstClus);		/* Sub-directory cluster */
3899:../../Extensions/fatfs//src/ff.c **** 						fs->cdc_scl = dj.obj.sclust;						/* Save containing directory information */
3900:../../Extensions/fatfs//src/ff.c **** 						fs->cdc_size = ((DWORD)dj.obj.objsize & 0xFFFFFF00) | dj.obj.stat;
3901:../../Extensions/fatfs//src/ff.c **** 						fs->cdc_ofs = dj.blk_ofs;
3902:../../Extensions/fatfs//src/ff.c **** 					} else
3903:../../Extensions/fatfs//src/ff.c **** #endif
