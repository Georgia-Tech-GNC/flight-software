 552:Core/Src/port.c **** void xPortSysTickHandler( void )
 553:Core/Src/port.c **** {
 554:Core/Src/port.c ****     /* The SysTick runs at the lowest interrupt priority, so when this interrupt
 555:Core/Src/port.c ****      * executes all interrupts must be unmasked.  There is therefore no need to
 556:Core/Src/port.c ****      * save and then restore the interrupt mask value as its value is already
 557:Core/Src/port.c ****      * known. */
 558:Core/Src/port.c ****     portDISABLE_INTERRUPTS();
 559:Core/Src/port.c ****     traceISR_ENTER();
 560:Core/Src/port.c ****     {
 561:Core/Src/port.c ****         /* Increment the RTOS tick. */
 562:Core/Src/port.c ****         if( xTaskIncrementTick() != pdFALSE )
 563:Core/Src/port.c ****         {
 564:Core/Src/port.c ****             traceISR_EXIT_TO_SCHEDULER();
 565:Core/Src/port.c **** 
 566:Core/Src/port.c ****             /* A context switch is required.  Context switching is performed in
 567:Core/Src/port.c ****              * the PendSV interrupt.  Pend the PendSV interrupt. */
 568:Core/Src/port.c ****             portNVIC_INT_CTRL_REG = portNVIC_PENDSVSET_BIT;
 569:Core/Src/port.c ****         }
 570:Core/Src/port.c ****         else
 571:Core/Src/port.c ****         {
 572:Core/Src/port.c ****             traceISR_EXIT();
 573:Core/Src/port.c ****         }
 574:Core/Src/port.c ****     }
 575:Core/Src/port.c ****     portENABLE_INTERRUPTS();
 576:Core/Src/port.c **** }
