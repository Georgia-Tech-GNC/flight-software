3757:../../Extensions/fatfs//src/ff.c **** 			if (fs->fs_type == FS_EXFAT) {
3758:../../Extensions/fatfs//src/ff.c **** 				res = fill_first_frag(&fp->obj);	/* Fill first fragment on the FAT if needed */
3759:../../Extensions/fatfs//src/ff.c **** 				if (res == FR_OK) {
