4510:../Core/FreeRTOS-Kernel/tasks.c ****         /* Correct the tick count value after a period during which the tick
4511:../Core/FreeRTOS-Kernel/tasks.c ****          * was suppressed.  Note this does *not* call the tick hook function for
4512:../Core/FreeRTOS-Kernel/tasks.c ****          * each stepped tick. */
4513:../Core/FreeRTOS-Kernel/tasks.c ****         xUpdatedTickCount = xTickCount + xTicksToJump;
4514:../Core/FreeRTOS-Kernel/tasks.c ****         configASSERT( xUpdatedTickCount <= xNextTaskUnblockTime );
4515:../Core/FreeRTOS-Kernel/tasks.c **** 
4516:../Core/FreeRTOS-Kernel/tasks.c ****         if( xUpdatedTickCount == xNextTaskUnblockTime )
4517:../Core/FreeRTOS-Kernel/tasks.c ****         {
4518:../Core/FreeRTOS-Kernel/tasks.c ****             /* Arrange for xTickCount to reach xNextTaskUnblockTime in
4519:../Core/FreeRTOS-Kernel/tasks.c ****              * xTaskIncrementTick() when the scheduler resumes.  This ensures
4520:../Core/FreeRTOS-Kernel/tasks.c ****              * that any delayed tasks are resumed at the correct time. */
4521:../Core/FreeRTOS-Kernel/tasks.c ****             configASSERT( uxSchedulerSuspended != ( UBaseType_t ) 0U );
4522:../Core/FreeRTOS-Kernel/tasks.c ****             configASSERT( xTicksToJump != ( TickType_t ) 0 );
4523:../Core/FreeRTOS-Kernel/tasks.c **** 
4524:../Core/FreeRTOS-Kernel/tasks.c ****             /* Prevent the tick interrupt modifying xPendedTicks simultaneously. */
4525:../Core/FreeRTOS-Kernel/tasks.c ****             taskENTER_CRITICAL();
4526:../Core/FreeRTOS-Kernel/tasks.c ****             {
