 300:Core/Src/port.c **** BaseType_t xPortStartScheduler( void )
 301:Core/Src/port.c **** {
 302:Core/Src/port.c ****     /* An application can install FreeRTOS interrupt handlers in one of the
 303:Core/Src/port.c ****      * following ways:
 304:Core/Src/port.c ****      * 1. Direct Routing - Install the functions vPortSVCHandler and
 305:Core/Src/port.c ****      *    xPortPendSVHandler for SVCall and PendSV interrupts respectively.
 306:Core/Src/port.c ****      * 2. Indirect Routing - Install separate handlers for SVCall and PendSV
 307:Core/Src/port.c ****      *    interrupts and route program control from those handlers to
 308:Core/Src/port.c ****      *    vPortSVCHandler and xPortPendSVHandler functions.
 309:Core/Src/port.c ****      *
 310:Core/Src/port.c ****      * Applications that use Indirect Routing must set
 311:Core/Src/port.c ****      * configCHECK_HANDLER_INSTALLATION to 0 in their FreeRTOSConfig.h. Direct
 312:Core/Src/port.c ****      * routing, which is validated here when configCHECK_HANDLER_INSTALLATION
 313:Core/Src/port.c ****      * is 1, should be preferred when possible. */
 314:Core/Src/port.c ****     #if ( configCHECK_HANDLER_INSTALLATION == 1 )
 315:Core/Src/port.c ****     {
 316:Core/Src/port.c ****         const portISR_t * const pxVectorTable = portSCB_VTOR_REG;
 317:Core/Src/port.c **** 
 318:Core/Src/port.c ****         /* Validate that the application has correctly installed the FreeRTOS
 319:Core/Src/port.c ****          * handlers for SVCall and PendSV interrupts. We do not check the
 320:Core/Src/port.c ****          * installation of the SysTick handler because the application may
 321:Core/Src/port.c ****          * choose to drive the RTOS tick using a timer other than the SysTick
 322:Core/Src/port.c ****          * timer by overriding the weak function vPortSetupTimerInterrupt().
 323:Core/Src/port.c ****          *
 324:Core/Src/port.c ****          * Assertion failures here indicate incorrect installation of the
 325:Core/Src/port.c ****          * FreeRTOS handlers. For help installing the FreeRTOS handlers, see
 326:Core/Src/port.c ****          * https://www.FreeRTOS.org/FAQHelp.html.
 327:Core/Src/port.c ****          *
 328:Core/Src/port.c ****          * Systems with a configurable address for the interrupt vector table
 329:Core/Src/port.c ****          * can also encounter assertion failures or even system faults here if
 330:Core/Src/port.c ****          * VTOR is not set correctly to point to the application's vector table. */
 331:Core/Src/port.c ****         configASSERT( pxVectorTable[ portVECTOR_INDEX_SVC ] == vPortSVCHandler );
 332:Core/Src/port.c ****         configASSERT( pxVectorTable[ portVECTOR_INDEX_PENDSV ] == xPortPendSVHandler );
 333:Core/Src/port.c ****     }
 334:Core/Src/port.c ****     #endif /* configCHECK_HANDLER_INSTALLATION */
 335:Core/Src/port.c **** 
 336:Core/Src/port.c ****     #if ( configASSERT_DEFINED == 1 )
 337:Core/Src/port.c ****     {
 338:Core/Src/port.c ****         volatile uint8_t ucOriginalPriority;
 339:Core/Src/port.c ****         volatile uint32_t ulImplementedPrioBits = 0;
 340:Core/Src/port.c ****         volatile uint8_t * const pucFirstUserPriorityRegister = ( volatile uint8_t * const ) ( port
 341:Core/Src/port.c ****         volatile uint8_t ucMaxPriorityValue;
 342:Core/Src/port.c **** 
 343:Core/Src/port.c ****         /* Determine the maximum priority from which ISR safe FreeRTOS API
 344:Core/Src/port.c ****          * functions can be called.  ISR safe functions are those that end in
 345:Core/Src/port.c ****          * "FromISR".  FreeRTOS maintains separate thread and ISR API functions to
 346:Core/Src/port.c ****          * ensure interrupt entry is as fast and simple as possible.
 347:Core/Src/port.c ****          *
 348:Core/Src/port.c ****          * Save the interrupt priority value that is about to be clobbered. */
 349:Core/Src/port.c ****         ucOriginalPriority = *pucFirstUserPriorityRegister;
 350:Core/Src/port.c **** 
ARM GAS  /tmp/ccw37vfO.s 			page 13


 351:Core/Src/port.c ****         /* Determine the number of priority bits available.  First write to all
 352:Core/Src/port.c ****          * possible bits. */
 353:Core/Src/port.c ****         *pucFirstUserPriorityRegister = portMAX_8_BIT_VALUE;
 354:Core/Src/port.c **** 
 355:Core/Src/port.c ****         /* Read the value back to see how many bits stuck. */
 356:Core/Src/port.c ****         ucMaxPriorityValue = *pucFirstUserPriorityRegister;
 357:Core/Src/port.c **** 
 358:Core/Src/port.c ****         /* Use the same mask on the maximum system call priority. */
 359:Core/Src/port.c ****         ucMaxSysCallPriority = configMAX_SYSCALL_INTERRUPT_PRIORITY & ucMaxPriorityValue;
 360:Core/Src/port.c **** 
 361:Core/Src/port.c ****         /* Check that the maximum system call priority is nonzero after
 362:Core/Src/port.c ****          * accounting for the number of priority bits supported by the
 363:Core/Src/port.c ****          * hardware. A priority of 0 is invalid because setting the BASEPRI
 364:Core/Src/port.c ****          * register to 0 unmasks all interrupts, and interrupts with priority 0
 365:Core/Src/port.c ****          * cannot be masked using BASEPRI.
 366:Core/Src/port.c ****          * See https://www.FreeRTOS.org/RTOS-Cortex-M3-M4.html */
 367:Core/Src/port.c ****         configASSERT( ucMaxSysCallPriority );
 368:Core/Src/port.c **** 
 369:Core/Src/port.c ****         /* Check that the bits not implemented in hardware are zero in
 370:Core/Src/port.c ****          * configMAX_SYSCALL_INTERRUPT_PRIORITY. */
 371:Core/Src/port.c ****         configASSERT( ( configMAX_SYSCALL_INTERRUPT_PRIORITY & ( ~ucMaxPriorityValue ) ) == 0U );
 372:Core/Src/port.c **** 
 373:Core/Src/port.c ****         /* Calculate the maximum acceptable priority group value for the number
 374:Core/Src/port.c ****          * of bits read back. */
 375:Core/Src/port.c **** 
 376:Core/Src/port.c ****         while( ( ucMaxPriorityValue & portTOP_BIT_OF_BYTE ) == portTOP_BIT_OF_BYTE )
 377:Core/Src/port.c ****         {
