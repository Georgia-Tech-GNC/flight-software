4475:../../Extensions/fatfs//src/ff.c **** FRESULT f_truncate (
4476:../../Extensions/fatfs//src/ff.c **** 	FIL* fp		/* Pointer to the file object */
4477:../../Extensions/fatfs//src/ff.c **** )
4478:../../Extensions/fatfs//src/ff.c **** {
4479:../../Extensions/fatfs//src/ff.c **** 	FRESULT res;
4480:../../Extensions/fatfs//src/ff.c **** 	FATFS *fs;
4481:../../Extensions/fatfs//src/ff.c **** 	DWORD ncl;
4482:../../Extensions/fatfs//src/ff.c **** 
4483:../../Extensions/fatfs//src/ff.c **** 
4484:../../Extensions/fatfs//src/ff.c **** 	res = validate(&fp->obj, &fs);	/* Check validity of the file object */
4485:../../Extensions/fatfs//src/ff.c **** 	if (res != FR_OK || (res = (FRESULT)fp->err) != FR_OK) LEAVE_FF(fs, res);
4486:../../Extensions/fatfs//src/ff.c **** 	if (!(fp->flag & FA_WRITE)) LEAVE_FF(fs, FR_DENIED);	/* Check access mode */
4487:../../Extensions/fatfs//src/ff.c **** 
4488:../../Extensions/fatfs//src/ff.c **** 	if (fp->fptr < fp->obj.objsize) {	/* Process when fptr is not on the eof */
4489:../../Extensions/fatfs//src/ff.c **** 		if (fp->fptr == 0) {	/* When set file size to zero, remove entire cluster chain */
4490:../../Extensions/fatfs//src/ff.c **** 			res = remove_chain(&fp->obj, fp->obj.sclust, 0);
4491:../../Extensions/fatfs//src/ff.c **** 			fp->obj.sclust = 0;
4492:../../Extensions/fatfs//src/ff.c **** 		} else {				/* When truncate a part of the file, remove remaining clusters */
4493:../../Extensions/fatfs//src/ff.c **** 			ncl = get_fat(&fp->obj, fp->clust);
4494:../../Extensions/fatfs//src/ff.c **** 			res = FR_OK;
4495:../../Extensions/fatfs//src/ff.c **** 			if (ncl == 0xFFFFFFFF) res = FR_DISK_ERR;
4496:../../Extensions/fatfs//src/ff.c **** 			if (ncl == 1) res = FR_INT_ERR;
4497:../../Extensions/fatfs//src/ff.c **** 			if (res == FR_OK && ncl < fs->n_fatent) {
4498:../../Extensions/fatfs//src/ff.c **** 				res = remove_chain(&fp->obj, ncl, fp->clust);
4499:../../Extensions/fatfs//src/ff.c **** 			}
4500:../../Extensions/fatfs//src/ff.c **** 		}
4501:../../Extensions/fatfs//src/ff.c **** 		fp->obj.objsize = fp->fptr;	/* Set file size to current R/W point */
4502:../../Extensions/fatfs//src/ff.c **** 		fp->flag |= FA_MODIFIED;
4503:../../Extensions/fatfs//src/ff.c **** #if !_FS_TINY
4504:../../Extensions/fatfs//src/ff.c **** 		if (res == FR_OK && (fp->flag & FA_DIRTY)) {
4505:../../Extensions/fatfs//src/ff.c **** 			if (disk_write(fs->drv, fp->buf, fp->sect, 1) != RES_OK) {
4506:../../Extensions/fatfs//src/ff.c **** 				res = FR_DISK_ERR;
4507:../../Extensions/fatfs//src/ff.c **** 			} else {
4508:../../Extensions/fatfs//src/ff.c **** 				fp->flag &= (BYTE)~FA_DIRTY;
4509:../../Extensions/fatfs//src/ff.c **** 			}
4510:../../Extensions/fatfs//src/ff.c **** 		}
4511:../../Extensions/fatfs//src/ff.c **** #endif
4512:../../Extensions/fatfs//src/ff.c **** 		if (res != FR_OK) ABORT(fs, res);
4513:../../Extensions/fatfs//src/ff.c **** 	}
4514:../../Extensions/fatfs//src/ff.c **** 
4515:../../Extensions/fatfs//src/ff.c **** 	LEAVE_FF(fs, res);
4516:../../Extensions/fatfs//src/ff.c **** }
