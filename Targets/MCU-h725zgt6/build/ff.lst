3765:../../Extensions/fatfs//src/ff.c **** 					if (res == FR_OK) {
3766:../../Extensions/fatfs//src/ff.c **** 						fs->dirbuf[XDIR_Attr] |= AM_ARC;				/* Set archive bit */
3767:../../Extensions/fatfs//src/ff.c **** 						fs->dirbuf[XDIR_GenFlags] = fp->obj.stat | 1;	/* Update file allocation info */
