1000:../../Extensions/fatfs//src/ff.c **** static
1001:../../Extensions/fatfs//src/ff.c **** DWORD get_fat (	/* 0xFFFFFFFF:Disk error, 1:Internal error, 2..0x7FFFFFFF:Cluster status */
1002:../../Extensions/fatfs//src/ff.c **** 	_FDID* obj,	/* Corresponding object */
1003:../../Extensions/fatfs//src/ff.c **** 	DWORD clst	/* Cluster number to get the value */
1004:../../Extensions/fatfs//src/ff.c **** )
1005:../../Extensions/fatfs//src/ff.c **** {
1006:../../Extensions/fatfs//src/ff.c **** 	UINT wc, bc;
1007:../../Extensions/fatfs//src/ff.c **** 	DWORD val;
1008:../../Extensions/fatfs//src/ff.c **** 	FATFS *fs = obj->fs;
1009:../../Extensions/fatfs//src/ff.c **** 
1010:../../Extensions/fatfs//src/ff.c **** 
1011:../../Extensions/fatfs//src/ff.c **** 	if (clst < 2 || clst >= fs->n_fatent) {	/* Check if in valid range */
1012:../../Extensions/fatfs//src/ff.c **** 		val = 1;	/* Internal error */
1013:../../Extensions/fatfs//src/ff.c **** 
ARM GAS  /var/folders/cy/8kgpsxf90rz6cg1g85ws44fm0000gn/T//ccqN9xZo.s 			page 36


1014:../../Extensions/fatfs//src/ff.c **** 	} else {
1015:../../Extensions/fatfs//src/ff.c **** 		val = 0xFFFFFFFF;	/* Default value falls on disk error */
1016:../../Extensions/fatfs//src/ff.c **** 
1017:../../Extensions/fatfs//src/ff.c **** 		switch (fs->fs_type) {
1018:../../Extensions/fatfs//src/ff.c **** 		case FS_FAT12 :
1019:../../Extensions/fatfs//src/ff.c **** 			bc = (UINT)clst; bc += bc / 2;
1020:../../Extensions/fatfs//src/ff.c **** 			if (move_window(fs, fs->fatbase + (bc / SS(fs))) != FR_OK) break;
1021:../../Extensions/fatfs//src/ff.c **** 			wc = fs->win[bc++ % SS(fs)];
1022:../../Extensions/fatfs//src/ff.c **** 			if (move_window(fs, fs->fatbase + (bc / SS(fs))) != FR_OK) break;
1023:../../Extensions/fatfs//src/ff.c **** 			wc |= fs->win[bc % SS(fs)] << 8;
1024:../../Extensions/fatfs//src/ff.c **** 			val = (clst & 1) ? (wc >> 4) : (wc & 0xFFF);
1025:../../Extensions/fatfs//src/ff.c **** 			break;
1026:../../Extensions/fatfs//src/ff.c **** 
1027:../../Extensions/fatfs//src/ff.c **** 		case FS_FAT16 :
1028:../../Extensions/fatfs//src/ff.c **** 			if (move_window(fs, fs->fatbase + (clst / (SS(fs) / 2))) != FR_OK) break;
1029:../../Extensions/fatfs//src/ff.c **** 			val = ld_word(fs->win + clst * 2 % SS(fs));
1030:../../Extensions/fatfs//src/ff.c **** 			break;
1031:../../Extensions/fatfs//src/ff.c **** 
1032:../../Extensions/fatfs//src/ff.c **** 		case FS_FAT32 :
1033:../../Extensions/fatfs//src/ff.c **** 			if (move_window(fs, fs->fatbase + (clst / (SS(fs) / 4))) != FR_OK) break;
1034:../../Extensions/fatfs//src/ff.c **** 			val = ld_dword(fs->win + clst * 4 % SS(fs)) & 0x0FFFFFFF;
1035:../../Extensions/fatfs//src/ff.c **** 			break;
1036:../../Extensions/fatfs//src/ff.c **** #if _FS_EXFAT
1037:../../Extensions/fatfs//src/ff.c **** 		case FS_EXFAT :
1038:../../Extensions/fatfs//src/ff.c **** 			if (obj->objsize) {
1039:../../Extensions/fatfs//src/ff.c **** 				DWORD cofs = clst - obj->sclust;	/* Offset from start cluster */
1040:../../Extensions/fatfs//src/ff.c **** 				DWORD clen = (DWORD)((obj->objsize - 1) / SS(fs)) / fs->csize;	/* Number of clusters - 1 */
1041:../../Extensions/fatfs//src/ff.c **** 
1042:../../Extensions/fatfs//src/ff.c **** 				if (obj->stat == 2) {	/* Is there no valid chain on the FAT? */
1043:../../Extensions/fatfs//src/ff.c **** 					if (cofs <= clen) {
1044:../../Extensions/fatfs//src/ff.c **** 						val = (cofs == clen) ? 0x7FFFFFFF : clst + 1;	/* Generate the value */
1045:../../Extensions/fatfs//src/ff.c **** 						break;
1046:../../Extensions/fatfs//src/ff.c **** 					}
1047:../../Extensions/fatfs//src/ff.c **** 				}
1048:../../Extensions/fatfs//src/ff.c **** 				if (obj->stat == 3 && cofs < obj->n_cont) {	/* Is it in the 1st fragment? */
1049:../../Extensions/fatfs//src/ff.c **** 					val = clst + 1; 	/* Generate the value */
1050:../../Extensions/fatfs//src/ff.c **** 					break;
1051:../../Extensions/fatfs//src/ff.c **** 				}
1052:../../Extensions/fatfs//src/ff.c **** 				if (obj->stat != 2) {	/* Get value from FAT if FAT chain is valid */
1053:../../Extensions/fatfs//src/ff.c **** 					if (obj->n_frag != 0) {	/* Is it on the growing edge? */
1054:../../Extensions/fatfs//src/ff.c **** 						val = 0x7FFFFFFF;	/* Generate EOC */
1055:../../Extensions/fatfs//src/ff.c **** 					} else {
1056:../../Extensions/fatfs//src/ff.c **** 						if (move_window(fs, fs->fatbase + (clst / (SS(fs) / 4))) != FR_OK) break;
1057:../../Extensions/fatfs//src/ff.c **** 						val = ld_dword(fs->win + clst * 4 % SS(fs)) & 0x7FFFFFFF;
1058:../../Extensions/fatfs//src/ff.c **** 					}
1059:../../Extensions/fatfs//src/ff.c **** 					break;
1060:../../Extensions/fatfs//src/ff.c **** 				}
1061:../../Extensions/fatfs//src/ff.c **** 			}
1062:../../Extensions/fatfs//src/ff.c **** 			/* go to default */
1063:../../Extensions/fatfs//src/ff.c **** #endif
1064:../../Extensions/fatfs//src/ff.c **** 		default:
1065:../../Extensions/fatfs//src/ff.c **** 			val = 1;	/* Internal error */
1066:../../Extensions/fatfs//src/ff.c **** 		}
1067:../../Extensions/fatfs//src/ff.c **** 	}
1068:../../Extensions/fatfs//src/ff.c **** 
1069:../../Extensions/fatfs//src/ff.c **** 	return val;
1070:../../Extensions/fatfs//src/ff.c **** }
