2714:../Core/FreeRTOS-Kernel/queue.c **** 
2715:../Core/FreeRTOS-Kernel/queue.c ****         /* If the queue is already full we may have to block.  A critical section
2716:../Core/FreeRTOS-Kernel/queue.c ****          * is required to prevent an interrupt removing something from the queue
2717:../Core/FreeRTOS-Kernel/queue.c ****          * between the check to see if the queue is full and blocking on the queue. */
2718:../Core/FreeRTOS-Kernel/queue.c ****         portDISABLE_INTERRUPTS();
2719:../Core/FreeRTOS-Kernel/queue.c ****         {
2720:../Core/FreeRTOS-Kernel/queue.c ****             if( prvIsQueueFull( pxQueue ) != pdFALSE )
2721:../Core/FreeRTOS-Kernel/queue.c ****             {
2722:../Core/FreeRTOS-Kernel/queue.c ****                 /* The queue is full - do we want to block or just leave without
2723:../Core/FreeRTOS-Kernel/queue.c ****                  * posting? */
2724:../Core/FreeRTOS-Kernel/queue.c ****                 if( xTicksToWait > ( TickType_t ) 0 )
2725:../Core/FreeRTOS-Kernel/queue.c ****                 {
2726:../Core/FreeRTOS-Kernel/queue.c ****                     /* As this is called from a coroutine we cannot block directly, but
2727:../Core/FreeRTOS-Kernel/queue.c ****                      * return indicating that we need to block. */
2728:../Core/FreeRTOS-Kernel/queue.c ****                     vCoRoutineAddToDelayedList( xTicksToWait, &( pxQueue->xTasksWaitingToSend ) );
2729:../Core/FreeRTOS-Kernel/queue.c ****                     portENABLE_INTERRUPTS();
2730:../Core/FreeRTOS-Kernel/queue.c ****                     return errQUEUE_BLOCKED;
2731:../Core/FreeRTOS-Kernel/queue.c ****                 }
2732:../Core/FreeRTOS-Kernel/queue.c ****                 else
2733:../Core/FreeRTOS-Kernel/queue.c ****                 {
2734:../Core/FreeRTOS-Kernel/queue.c ****                     portENABLE_INTERRUPTS();
2735:../Core/FreeRTOS-Kernel/queue.c ****                     return errQUEUE_FULL;
2736:../Core/FreeRTOS-Kernel/queue.c ****                 }
2737:../Core/FreeRTOS-Kernel/queue.c ****             }
2738:../Core/FreeRTOS-Kernel/queue.c ****         }
2739:../Core/FreeRTOS-Kernel/queue.c ****         portENABLE_INTERRUPTS();
2740:../Core/FreeRTOS-Kernel/queue.c **** 
2741:../Core/FreeRTOS-Kernel/queue.c ****         portDISABLE_INTERRUPTS();
2742:../Core/FreeRTOS-Kernel/queue.c ****         {
