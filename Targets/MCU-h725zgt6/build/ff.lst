5826:../../Extensions/fatfs//src/ff.c **** /*-----------------------------------------------------------------------*/
5827:../../Extensions/fatfs//src/ff.c **** /* Get a string from the file                                            */
5828:../../Extensions/fatfs//src/ff.c **** /*-----------------------------------------------------------------------*/
5829:../../Extensions/fatfs//src/ff.c **** 
5830:../../Extensions/fatfs//src/ff.c **** TCHAR* f_gets (
5831:../../Extensions/fatfs//src/ff.c **** 	TCHAR* buff,	/* Pointer to the string buffer to read */
5832:../../Extensions/fatfs//src/ff.c **** 	int len,		/* Size of string buffer (characters) */
5833:../../Extensions/fatfs//src/ff.c **** 	FIL* fp			/* Pointer to the file object */
5834:../../Extensions/fatfs//src/ff.c **** )
5835:../../Extensions/fatfs//src/ff.c **** {
5836:../../Extensions/fatfs//src/ff.c **** 	int n = 0;
5837:../../Extensions/fatfs//src/ff.c **** 	TCHAR c, *p = buff;
5838:../../Extensions/fatfs//src/ff.c **** 	BYTE s[2];
5839:../../Extensions/fatfs//src/ff.c **** 	UINT rc;
5840:../../Extensions/fatfs//src/ff.c **** 
5841:../../Extensions/fatfs//src/ff.c **** 
ARM GAS  /var/folders/cy/8kgpsxf90rz6cg1g85ws44fm0000gn/T//ccqN9xZo.s 			page 137


5842:../../Extensions/fatfs//src/ff.c **** 	while (n < len - 1) {	/* Read characters until buffer gets filled */
5843:../../Extensions/fatfs//src/ff.c **** #if _LFN_UNICODE
5844:../../Extensions/fatfs//src/ff.c **** #if _STRF_ENCODE == 3		/* Read a character in UTF-8 */
5845:../../Extensions/fatfs//src/ff.c **** 		f_read(fp, s, 1, &rc);
5846:../../Extensions/fatfs//src/ff.c **** 		if (rc != 1) break;
5847:../../Extensions/fatfs//src/ff.c **** 		c = s[0];
5848:../../Extensions/fatfs//src/ff.c **** 		if (c >= 0x80) {
5849:../../Extensions/fatfs//src/ff.c **** 			if (c < 0xC0) continue;	/* Skip stray trailer */
5850:../../Extensions/fatfs//src/ff.c **** 			if (c < 0xE0) {			/* Two-byte sequence (0x80-0x7FF) */
5851:../../Extensions/fatfs//src/ff.c **** 				f_read(fp, s, 1, &rc);
5852:../../Extensions/fatfs//src/ff.c **** 				if (rc != 1) break;
5853:../../Extensions/fatfs//src/ff.c **** 				c = (c & 0x1F) << 6 | (s[0] & 0x3F);
5854:../../Extensions/fatfs//src/ff.c **** 				if (c < 0x80) c = '?';	/* Reject invalid code range */
5855:../../Extensions/fatfs//src/ff.c **** 			} else {
5856:../../Extensions/fatfs//src/ff.c **** 				if (c < 0xF0) {		/* Three-byte sequence (0x800-0xFFFF) */
5857:../../Extensions/fatfs//src/ff.c **** 					f_read(fp, s, 2, &rc);
5858:../../Extensions/fatfs//src/ff.c **** 					if (rc != 2) break;
5859:../../Extensions/fatfs//src/ff.c **** 					c = c << 12 | (s[0] & 0x3F) << 6 | (s[1] & 0x3F);
5860:../../Extensions/fatfs//src/ff.c **** 					if (c < 0x800) c = '?';	/* Reject invalid code range */
5861:../../Extensions/fatfs//src/ff.c **** 				} else {			/* Reject four-byte sequence */
5862:../../Extensions/fatfs//src/ff.c **** 					c = '?';
5863:../../Extensions/fatfs//src/ff.c **** 				}
5864:../../Extensions/fatfs//src/ff.c **** 			}
5865:../../Extensions/fatfs//src/ff.c **** 		}
5866:../../Extensions/fatfs//src/ff.c **** #elif _STRF_ENCODE == 2		/* Read a character in UTF-16BE */
5867:../../Extensions/fatfs//src/ff.c **** 		f_read(fp, s, 2, &rc);
5868:../../Extensions/fatfs//src/ff.c **** 		if (rc != 2) break;
5869:../../Extensions/fatfs//src/ff.c **** 		c = s[1] + (s[0] << 8);
5870:../../Extensions/fatfs//src/ff.c **** #elif _STRF_ENCODE == 1		/* Read a character in UTF-16LE */
5871:../../Extensions/fatfs//src/ff.c **** 		f_read(fp, s, 2, &rc);
5872:../../Extensions/fatfs//src/ff.c **** 		if (rc != 2) break;
5873:../../Extensions/fatfs//src/ff.c **** 		c = s[0] + (s[1] << 8);
5874:../../Extensions/fatfs//src/ff.c **** #else						/* Read a character in ANSI/OEM */
5875:../../Extensions/fatfs//src/ff.c **** 		f_read(fp, s, 1, &rc);
5876:../../Extensions/fatfs//src/ff.c **** 		if (rc != 1) break;
5877:../../Extensions/fatfs//src/ff.c **** 		c = s[0];
5878:../../Extensions/fatfs//src/ff.c **** 		if (IsDBCS1(c)) {
5879:../../Extensions/fatfs//src/ff.c **** 			f_read(fp, s, 1, &rc);
5880:../../Extensions/fatfs//src/ff.c **** 			if (rc != 1) break;
5881:../../Extensions/fatfs//src/ff.c **** 			c = (c << 8) + s[0];
5882:../../Extensions/fatfs//src/ff.c **** 		}
5883:../../Extensions/fatfs//src/ff.c **** 		c = ff_convert(c, 1);	/* OEM -> Unicode */
5884:../../Extensions/fatfs//src/ff.c **** 		if (!c) c = '?';
5885:../../Extensions/fatfs//src/ff.c **** #endif
5886:../../Extensions/fatfs//src/ff.c **** #else						/* Read a character without conversion */
5887:../../Extensions/fatfs//src/ff.c **** 		f_read(fp, s, 1, &rc);
5888:../../Extensions/fatfs//src/ff.c **** 		if (rc != 1) break;
5889:../../Extensions/fatfs//src/ff.c **** 		c = s[0];
5890:../../Extensions/fatfs//src/ff.c **** #endif
5891:../../Extensions/fatfs//src/ff.c **** 		if (_USE_STRFUNC == 2 && c == '\r') continue;	/* Strip '\r' */
5892:../../Extensions/fatfs//src/ff.c **** 		*p++ = c;
5893:../../Extensions/fatfs//src/ff.c **** 		n++;
5894:../../Extensions/fatfs//src/ff.c **** 		if (c == '\n') break;		/* Break on EOL */
5895:../../Extensions/fatfs//src/ff.c **** 	}
5896:../../Extensions/fatfs//src/ff.c **** 	*p = 0;
5897:../../Extensions/fatfs//src/ff.c **** 	return n ? buff : 0;			/* When no data read (eof or error), return with error. */
5898:../../Extensions/fatfs//src/ff.c **** }
