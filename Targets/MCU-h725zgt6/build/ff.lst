5905:../../Extensions/fatfs//src/ff.c **** /*-----------------------------------------------------------------------*/
5906:../../Extensions/fatfs//src/ff.c **** /* Put a character to the file                                           */
5907:../../Extensions/fatfs//src/ff.c **** /*-----------------------------------------------------------------------*/
5908:../../Extensions/fatfs//src/ff.c **** 
5909:../../Extensions/fatfs//src/ff.c **** typedef struct {
5910:../../Extensions/fatfs//src/ff.c **** 	FIL *fp;		/* Ptr to the writing file */
5911:../../Extensions/fatfs//src/ff.c **** 	int idx, nchr;	/* Write index of buf[] (-1:error), number of chars written */
5912:../../Extensions/fatfs//src/ff.c **** 	BYTE buf[64];	/* Write buffer */
5913:../../Extensions/fatfs//src/ff.c **** } putbuff;
5914:../../Extensions/fatfs//src/ff.c **** 
5915:../../Extensions/fatfs//src/ff.c **** 
5916:../../Extensions/fatfs//src/ff.c **** static
5917:../../Extensions/fatfs//src/ff.c **** void putc_bfd (		/* Buffered write with code conversion */
5918:../../Extensions/fatfs//src/ff.c **** 	putbuff* pb,
5919:../../Extensions/fatfs//src/ff.c **** 	TCHAR c
5920:../../Extensions/fatfs//src/ff.c **** )
5921:../../Extensions/fatfs//src/ff.c **** {
5922:../../Extensions/fatfs//src/ff.c **** 	UINT bw;
5923:../../Extensions/fatfs//src/ff.c **** 	int i;
5924:../../Extensions/fatfs//src/ff.c **** 
5925:../../Extensions/fatfs//src/ff.c **** 
5926:../../Extensions/fatfs//src/ff.c **** 	if (_USE_STRFUNC == 2 && c == '\n') {	 /* LF -> CRLF conversion */
5927:../../Extensions/fatfs//src/ff.c **** 		putc_bfd(pb, '\r');
5928:../../Extensions/fatfs//src/ff.c **** 	}
5929:../../Extensions/fatfs//src/ff.c **** 
5930:../../Extensions/fatfs//src/ff.c **** 	i = pb->idx;		/* Write index of pb->buf[] */
5931:../../Extensions/fatfs//src/ff.c **** 	if (i < 0) return;
5932:../../Extensions/fatfs//src/ff.c **** 
5933:../../Extensions/fatfs//src/ff.c **** #if _LFN_UNICODE
5934:../../Extensions/fatfs//src/ff.c **** #if _STRF_ENCODE == 3			/* Write a character in UTF-8 */
5935:../../Extensions/fatfs//src/ff.c **** 	if (c < 0x80) {				/* 7-bit */
5936:../../Extensions/fatfs//src/ff.c **** 		pb->buf[i++] = (BYTE)c;
5937:../../Extensions/fatfs//src/ff.c **** 	} else {
5938:../../Extensions/fatfs//src/ff.c **** 		if (c < 0x800) {		/* 11-bit */
5939:../../Extensions/fatfs//src/ff.c **** 			pb->buf[i++] = (BYTE)(0xC0 | c >> 6);
5940:../../Extensions/fatfs//src/ff.c **** 		} else {				/* 16-bit */
5941:../../Extensions/fatfs//src/ff.c **** 			pb->buf[i++] = (BYTE)(0xE0 | c >> 12);
5942:../../Extensions/fatfs//src/ff.c **** 			pb->buf[i++] = (BYTE)(0x80 | (c >> 6 & 0x3F));
5943:../../Extensions/fatfs//src/ff.c **** 		}
5944:../../Extensions/fatfs//src/ff.c **** 		pb->buf[i++] = (BYTE)(0x80 | (c & 0x3F));
5945:../../Extensions/fatfs//src/ff.c **** 	}
5946:../../Extensions/fatfs//src/ff.c **** #elif _STRF_ENCODE == 2			/* Write a character in UTF-16BE */
5947:../../Extensions/fatfs//src/ff.c **** 	pb->buf[i++] = (BYTE)(c >> 8);
5948:../../Extensions/fatfs//src/ff.c **** 	pb->buf[i++] = (BYTE)c;
5949:../../Extensions/fatfs//src/ff.c **** #elif _STRF_ENCODE == 1			/* Write a character in UTF-16LE */
5950:../../Extensions/fatfs//src/ff.c **** 	pb->buf[i++] = (BYTE)c;
5951:../../Extensions/fatfs//src/ff.c **** 	pb->buf[i++] = (BYTE)(c >> 8);
5952:../../Extensions/fatfs//src/ff.c **** #else							/* Write a character in ANSI/OEM */
5953:../../Extensions/fatfs//src/ff.c **** 	c = ff_convert(c, 0);	/* Unicode -> OEM */
5954:../../Extensions/fatfs//src/ff.c **** 	if (!c) c = '?';
5955:../../Extensions/fatfs//src/ff.c **** 	if (c >= 0x100)
ARM GAS  /var/folders/cy/8kgpsxf90rz6cg1g85ws44fm0000gn/T//ccqN9xZo.s 			page 139


5956:../../Extensions/fatfs//src/ff.c **** 		pb->buf[i++] = (BYTE)(c >> 8);
5957:../../Extensions/fatfs//src/ff.c **** 	pb->buf[i++] = (BYTE)c;
5958:../../Extensions/fatfs//src/ff.c **** #endif
5959:../../Extensions/fatfs//src/ff.c **** #else							/* Write a character without conversion */
5960:../../Extensions/fatfs//src/ff.c **** 	pb->buf[i++] = (BYTE)c;
5961:../../Extensions/fatfs//src/ff.c **** #endif
5962:../../Extensions/fatfs//src/ff.c **** 
5963:../../Extensions/fatfs//src/ff.c **** 	if (i >= (int)(sizeof pb->buf) - 3) {	/* Write buffered characters to the file */
5964:../../Extensions/fatfs//src/ff.c **** 		f_write(pb->fp, pb->buf, (UINT)i, &bw);
5965:../../Extensions/fatfs//src/ff.c **** 		i = (bw == (UINT)i) ? 0 : -1;
5966:../../Extensions/fatfs//src/ff.c **** 	}
5967:../../Extensions/fatfs//src/ff.c **** 	pb->idx = i;
5968:../../Extensions/fatfs//src/ff.c **** 	pb->nchr++;
5969:../../Extensions/fatfs//src/ff.c **** }
5970:../../Extensions/fatfs//src/ff.c **** 
5971:../../Extensions/fatfs//src/ff.c **** 
5972:../../Extensions/fatfs//src/ff.c **** static
5973:../../Extensions/fatfs//src/ff.c **** int putc_flush (		/* Flush left characters in the buffer */
5974:../../Extensions/fatfs//src/ff.c **** 	putbuff* pb
5975:../../Extensions/fatfs//src/ff.c **** )
5976:../../Extensions/fatfs//src/ff.c **** {
5977:../../Extensions/fatfs//src/ff.c **** 	UINT nw;
5978:../../Extensions/fatfs//src/ff.c **** 
5979:../../Extensions/fatfs//src/ff.c **** 	if (   pb->idx >= 0	/* Flush buffered characters to the file */
5980:../../Extensions/fatfs//src/ff.c **** 		&& f_write(pb->fp, pb->buf, (UINT)pb->idx, &nw) == FR_OK
5981:../../Extensions/fatfs//src/ff.c **** 		&& (UINT)pb->idx == nw) return pb->nchr;
5982:../../Extensions/fatfs//src/ff.c **** 	return EOF;
5983:../../Extensions/fatfs//src/ff.c **** }
