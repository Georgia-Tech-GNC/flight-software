3933:../../Extensions/fatfs//src/ff.c **** 	DEF_NAMBUF
3934:../../Extensions/fatfs//src/ff.c **** 
3935:../../Extensions/fatfs//src/ff.c **** 
3936:../../Extensions/fatfs//src/ff.c **** 	*buff = 0;
3937:../../Extensions/fatfs//src/ff.c **** 	/* Get logical drive */
3938:../../Extensions/fatfs//src/ff.c **** 	res = find_volume((const TCHAR**)&buff, &fs, 0);	/* Get current volume */
3939:../../Extensions/fatfs//src/ff.c **** 	if (res == FR_OK) {
3940:../../Extensions/fatfs//src/ff.c **** 		dj.obj.fs = fs;
3941:../../Extensions/fatfs//src/ff.c **** 		INIT_NAMBUF(fs);
3942:../../Extensions/fatfs//src/ff.c **** 		i = len;			/* Bottom of buffer (directory stack base) */
3943:../../Extensions/fatfs//src/ff.c **** 		if (!_FS_EXFAT || fs->fs_type != FS_EXFAT) {	/* (Cannot do getcwd on exFAT and returns root path)
3944:../../Extensions/fatfs//src/ff.c **** 			dj.obj.sclust = fs->cdir;				/* Start to follow upper directory from current directory */
3945:../../Extensions/fatfs//src/ff.c **** 			while ((ccl = dj.obj.sclust) != 0) {	/* Repeat while current directory is a sub-directory */
3946:../../Extensions/fatfs//src/ff.c **** 				res = dir_sdi(&dj, 1 * SZDIRE);	/* Get parent directory */
3947:../../Extensions/fatfs//src/ff.c **** 				if (res != FR_OK) break;
3948:../../Extensions/fatfs//src/ff.c **** 				res = move_window(fs, dj.sect);
3949:../../Extensions/fatfs//src/ff.c **** 				if (res != FR_OK) break;
3950:../../Extensions/fatfs//src/ff.c **** 				dj.obj.sclust = ld_clust(fs, dj.dir);	/* Goto parent directory */
3951:../../Extensions/fatfs//src/ff.c **** 				res = dir_sdi(&dj, 0);
3952:../../Extensions/fatfs//src/ff.c **** 				if (res != FR_OK) break;
3953:../../Extensions/fatfs//src/ff.c **** 				do {							/* Find the entry links to the child directory */
3954:../../Extensions/fatfs//src/ff.c **** 					res = dir_read(&dj, 0);
3955:../../Extensions/fatfs//src/ff.c **** 					if (res != FR_OK) break;
3956:../../Extensions/fatfs//src/ff.c **** 					if (ccl == ld_clust(fs, dj.dir)) break;	/* Found the entry */
3957:../../Extensions/fatfs//src/ff.c **** 					res = dir_next(&dj, 0);
3958:../../Extensions/fatfs//src/ff.c **** 				} while (res == FR_OK);
3959:../../Extensions/fatfs//src/ff.c **** 				if (res == FR_NO_FILE) res = FR_INT_ERR;/* It cannot be 'not found'. */
3960:../../Extensions/fatfs//src/ff.c **** 				if (res != FR_OK) break;
ARM GAS  /var/folders/cy/8kgpsxf90rz6cg1g85ws44fm0000gn/T//ccqN9xZo.s 			page 104


3961:../../Extensions/fatfs//src/ff.c **** 				get_fileinfo(&dj, &fno);		/* Get the directory name and push it to the buffer */
3962:../../Extensions/fatfs//src/ff.c **** 				for (n = 0; fno.fname[n]; n++) ;
3963:../../Extensions/fatfs//src/ff.c **** 				if (i < n + 3) {
3964:../../Extensions/fatfs//src/ff.c **** 					res = FR_NOT_ENOUGH_CORE; break;
3965:../../Extensions/fatfs//src/ff.c **** 				}
3966:../../Extensions/fatfs//src/ff.c **** 				while (n) buff[--i] = fno.fname[--n];
3967:../../Extensions/fatfs//src/ff.c **** 				buff[--i] = '/';
3968:../../Extensions/fatfs//src/ff.c **** 			}
3969:../../Extensions/fatfs//src/ff.c **** 		}
3970:../../Extensions/fatfs//src/ff.c **** 		tp = buff;
3971:../../Extensions/fatfs//src/ff.c **** 		if (res == FR_OK) {
3972:../../Extensions/fatfs//src/ff.c **** #if _VOLUMES >= 2
3973:../../Extensions/fatfs//src/ff.c **** 			*tp++ = '0' + CurrVol;			/* Put drive number */
3974:../../Extensions/fatfs//src/ff.c **** 			*tp++ = ':';
3975:../../Extensions/fatfs//src/ff.c **** #endif
3976:../../Extensions/fatfs//src/ff.c **** 			if (i == len) {					/* Root-directory */
3977:../../Extensions/fatfs//src/ff.c **** 				*tp++ = '/';
3978:../../Extensions/fatfs//src/ff.c **** 			} else {						/* Sub-directroy */
3979:../../Extensions/fatfs//src/ff.c **** 				do		/* Add stacked path str */
3980:../../Extensions/fatfs//src/ff.c **** 					*tp++ = buff[i++];
3981:../../Extensions/fatfs//src/ff.c **** 				while (i < len);
3982:../../Extensions/fatfs//src/ff.c **** 			}
3983:../../Extensions/fatfs//src/ff.c **** 		}
3984:../../Extensions/fatfs//src/ff.c **** 		*tp = 0;
3985:../../Extensions/fatfs//src/ff.c **** 		FREE_NAMBUF();
