4285:../../Extensions/fatfs//src/ff.c **** 				res = dir_next(dp, 0);		/* Increment index for next */
4286:../../Extensions/fatfs//src/ff.c **** 				if (res == FR_NO_FILE) res = FR_OK;	/* Ignore end of directory now */
4287:../../Extensions/fatfs//src/ff.c **** 			}
4288:../../Extensions/fatfs//src/ff.c **** 			FREE_NAMBUF();
4289:../../Extensions/fatfs//src/ff.c **** 		}
4290:../../Extensions/fatfs//src/ff.c **** 	}
4291:../../Extensions/fatfs//src/ff.c **** 	LEAVE_FF(fs, res);
4292:../../Extensions/fatfs//src/ff.c **** }
