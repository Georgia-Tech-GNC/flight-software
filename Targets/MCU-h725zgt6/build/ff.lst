4552:../../Extensions/fatfs//src/ff.c **** 			if (dj.fn[NSFLAG] & NS_NONAME) {
4553:../../Extensions/fatfs//src/ff.c **** 				res = FR_INVALID_NAME;		/* Cannot remove the origin directory */
4554:../../Extensions/fatfs//src/ff.c **** 			} else {
