  73:../Core/Src/fatfs_sd.c **** /* wait SD ready */
  74:../Core/Src/fatfs_sd.c **** static uint8_t SD_ReadyWait(void)
  75:../Core/Src/fatfs_sd.c **** {
  76:../Core/Src/fatfs_sd.c **** 	uint8_t res;
  77:../Core/Src/fatfs_sd.c **** 
  78:../Core/Src/fatfs_sd.c **** 	/* timeout 500ms */
  79:../Core/Src/fatfs_sd.c **** 	Timer2 = HAL_GetTick() + 500;
  80:../Core/Src/fatfs_sd.c **** 
  81:../Core/Src/fatfs_sd.c **** 	/* if SD goes ready, receives 0xFF */
  82:../Core/Src/fatfs_sd.c **** 	do {
  83:../Core/Src/fatfs_sd.c **** 		res = SPI_RxByte();
  84:../Core/Src/fatfs_sd.c **** 	} while ((res != 0xFF) && HAL_GetTick() < Timer2);
  85:../Core/Src/fatfs_sd.c **** 
  86:../Core/Src/fatfs_sd.c **** 	return res;
  87:../Core/Src/fatfs_sd.c **** }
