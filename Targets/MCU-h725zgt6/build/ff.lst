2846:../../Extensions/fatfs//src/ff.c **** 	}
2847:../../Extensions/fatfs//src/ff.c **** #endif
2848:../../Extensions/fatfs//src/ff.c **** #endif
2849:../../Extensions/fatfs//src/ff.c **** 
2850:../../Extensions/fatfs//src/ff.c **** 	if ((UINT)*path < ' ') {				/* Null path name is the origin directory itself */
2851:../../Extensions/fatfs//src/ff.c **** 		dp->fn[NSFLAG] = NS_NONAME;
2852:../../Extensions/fatfs//src/ff.c **** 		res = dir_sdi(dp, 0);
2853:../../Extensions/fatfs//src/ff.c **** 
2854:../../Extensions/fatfs//src/ff.c **** 	} else {								/* Follow path */
2855:../../Extensions/fatfs//src/ff.c **** 		for (;;) {
2856:../../Extensions/fatfs//src/ff.c **** 			res = create_name(dp, &path);	/* Get a segment name of the path */
2857:../../Extensions/fatfs//src/ff.c **** 			if (res != FR_OK) break;
