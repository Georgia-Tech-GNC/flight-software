3869:../../Extensions/fatfs//src/ff.c **** FRESULT f_chdir (
3870:../../Extensions/fatfs//src/ff.c **** 	const TCHAR* path	/* Pointer to the directory path */
3871:../../Extensions/fatfs//src/ff.c **** )
3872:../../Extensions/fatfs//src/ff.c **** {
3873:../../Extensions/fatfs//src/ff.c **** 	FRESULT res;
3874:../../Extensions/fatfs//src/ff.c **** 	DIR dj;
