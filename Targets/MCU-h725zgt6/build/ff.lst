 944:../../Extensions/fatfs//src/ff.c **** FRESULT sync_fs (	/* FR_OK:succeeded, !=0:error */
 945:../../Extensions/fatfs//src/ff.c **** 	FATFS* fs		/* File system object */
 946:../../Extensions/fatfs//src/ff.c **** )
 947:../../Extensions/fatfs//src/ff.c **** {
 948:../../Extensions/fatfs//src/ff.c **** 	FRESULT res;
 949:../../Extensions/fatfs//src/ff.c **** 
 950:../../Extensions/fatfs//src/ff.c **** 
 951:../../Extensions/fatfs//src/ff.c **** 	res = sync_window(fs);
 952:../../Extensions/fatfs//src/ff.c **** 	if (res == FR_OK) {
 953:../../Extensions/fatfs//src/ff.c **** 		/* Update FSInfo sector if needed */
 954:../../Extensions/fatfs//src/ff.c **** 		if (fs->fs_type == FS_FAT32 && fs->fsi_flag == 1) {
 955:../../Extensions/fatfs//src/ff.c **** 			/* Create FSInfo structure */
 956:../../Extensions/fatfs//src/ff.c **** 			mem_set(fs->win, 0, SS(fs));
 957:../../Extensions/fatfs//src/ff.c **** 			st_word(fs->win + BS_55AA, 0xAA55);
 958:../../Extensions/fatfs//src/ff.c **** 			st_dword(fs->win + FSI_LeadSig, 0x41615252);
 959:../../Extensions/fatfs//src/ff.c **** 			st_dword(fs->win + FSI_StrucSig, 0x61417272);
 960:../../Extensions/fatfs//src/ff.c **** 			st_dword(fs->win + FSI_Free_Count, fs->free_clst);
 961:../../Extensions/fatfs//src/ff.c **** 			st_dword(fs->win + FSI_Nxt_Free, fs->last_clst);
 962:../../Extensions/fatfs//src/ff.c **** 			/* Write it into the FSInfo sector */
 963:../../Extensions/fatfs//src/ff.c **** 			fs->winsect = fs->volbase + 1;
 964:../../Extensions/fatfs//src/ff.c **** 			disk_write(fs->drv, fs->win, fs->winsect, 1);
 965:../../Extensions/fatfs//src/ff.c **** 			fs->fsi_flag = 0;
 966:../../Extensions/fatfs//src/ff.c **** 		}
 967:../../Extensions/fatfs//src/ff.c **** 		/* Make sure that no pending write process in the physical drive */
 968:../../Extensions/fatfs//src/ff.c **** 		if (disk_ioctl(fs->drv, CTRL_SYNC, 0) != RES_OK) res = FR_DISK_ERR;
 969:../../Extensions/fatfs//src/ff.c **** 	}
 970:../../Extensions/fatfs//src/ff.c **** 
 971:../../Extensions/fatfs//src/ff.c **** 	return res;
 972:../../Extensions/fatfs//src/ff.c **** }
