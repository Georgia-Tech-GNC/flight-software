 456:Core/Src/port.c **** void vPortEndScheduler( void )
 457:Core/Src/port.c **** {
 458:Core/Src/port.c ****     /* Not implemented in ports where there is nothing to return to.
 459:Core/Src/port.c ****      * Artificially force an assert. */
 460:Core/Src/port.c ****     configASSERT( uxCriticalNesting == 1000UL );
