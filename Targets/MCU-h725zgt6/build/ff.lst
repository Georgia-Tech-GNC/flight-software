 912:../../Extensions/fatfs//src/ff.c **** FRESULT move_window (	/* Returns FR_OK or FR_DISK_ERROR */
 913:../../Extensions/fatfs//src/ff.c **** 	FATFS* fs,			/* File system object */
 914:../../Extensions/fatfs//src/ff.c **** 	DWORD sector		/* Sector number to make appearance in the fs->win[] */
 915:../../Extensions/fatfs//src/ff.c **** )
 916:../../Extensions/fatfs//src/ff.c **** {
 917:../../Extensions/fatfs//src/ff.c **** 	FRESULT res = FR_OK;
 918:../../Extensions/fatfs//src/ff.c **** 
 919:../../Extensions/fatfs//src/ff.c **** 
 920:../../Extensions/fatfs//src/ff.c **** 	if (sector != fs->winsect) {	/* Window offset changed? */
 921:../../Extensions/fatfs//src/ff.c **** #if !_FS_READONLY
 922:../../Extensions/fatfs//src/ff.c **** 		res = sync_window(fs);		/* Write-back changes */
 923:../../Extensions/fatfs//src/ff.c **** #endif
 924:../../Extensions/fatfs//src/ff.c **** 		if (res == FR_OK) {			/* Fill sector window with new data */
 925:../../Extensions/fatfs//src/ff.c **** 			if (disk_read(fs->drv, fs->win, sector, 1) != RES_OK) {
 926:../../Extensions/fatfs//src/ff.c **** 				sector = 0xFFFFFFFF;	/* Invalidate window if data is not reliable */
 927:../../Extensions/fatfs//src/ff.c **** 				res = FR_DISK_ERR;
 928:../../Extensions/fatfs//src/ff.c **** 			}
 929:../../Extensions/fatfs//src/ff.c **** 			fs->winsect = sector;
 930:../../Extensions/fatfs//src/ff.c **** 		}
 931:../../Extensions/fatfs//src/ff.c **** 	}
 932:../../Extensions/fatfs//src/ff.c **** 	return res;
 933:../../Extensions/fatfs//src/ff.c **** }
