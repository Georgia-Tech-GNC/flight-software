 146:Core/Src/port.c **** /*
 147:Core/Src/port.c ****  * Used to catch tasks that attempt to return from their implementing function.
 148:Core/Src/port.c ****  */
 149:Core/Src/port.c **** static void prvTaskExitError( void );
 150:Core/Src/port.c **** 
 151:Core/Src/port.c **** /*-----------------------------------------------------------*/
 152:Core/Src/port.c **** 
 153:Core/Src/port.c **** /* Each task maintains its own interrupt status in the critical nesting
 154:Core/Src/port.c ****  * variable. */
 155:Core/Src/port.c **** static UBaseType_t uxCriticalNesting = 0xaaaaaaaa;
 156:Core/Src/port.c **** 
 157:Core/Src/port.c **** /*
 158:Core/Src/port.c ****  * The number of SysTick increments that make up one tick period.
 159:Core/Src/port.c ****  */
 160:Core/Src/port.c **** #if ( configUSE_TICKLESS_IDLE == 1 )
 161:Core/Src/port.c ****     static uint32_t ulTimerCountsForOneTick = 0;
 162:Core/Src/port.c **** #endif /* configUSE_TICKLESS_IDLE */
 163:Core/Src/port.c **** 
 164:Core/Src/port.c **** /*
 165:Core/Src/port.c ****  * The maximum number of tick periods that can be suppressed is limited by the
 166:Core/Src/port.c ****  * 24 bit resolution of the SysTick timer.
 167:Core/Src/port.c ****  */
 168:Core/Src/port.c **** #if ( configUSE_TICKLESS_IDLE == 1 )
 169:Core/Src/port.c ****     static uint32_t xMaximumPossibleSuppressedTicks = 0;
 170:Core/Src/port.c **** #endif /* configUSE_TICKLESS_IDLE */
 171:Core/Src/port.c **** 
 172:Core/Src/port.c **** /*
 173:Core/Src/port.c ****  * Compensate for the CPU cycles that pass while the SysTick is stopped (low
 174:Core/Src/port.c ****  * power functionality only.
 175:Core/Src/port.c ****  */
 176:Core/Src/port.c **** #if ( configUSE_TICKLESS_IDLE == 1 )
 177:Core/Src/port.c ****     static uint32_t ulStoppedTimerCompensation = 0;
 178:Core/Src/port.c **** #endif /* configUSE_TICKLESS_IDLE */
 179:Core/Src/port.c **** 
 180:Core/Src/port.c **** /*
 181:Core/Src/port.c ****  * Used by the portASSERT_IF_INTERRUPT_PRIORITY_INVALID() macro to ensure
 182:Core/Src/port.c ****  * FreeRTOS API functions are not called from interrupts that have been assigned
 183:Core/Src/port.c ****  * a priority above configMAX_SYSCALL_INTERRUPT_PRIORITY.
 184:Core/Src/port.c ****  */
 185:Core/Src/port.c **** #if ( configASSERT_DEFINED == 1 )
 186:Core/Src/port.c ****     static uint8_t ucMaxSysCallPriority = 0;
 187:Core/Src/port.c ****     static uint32_t ulMaxPRIGROUPValue = 0;
 188:Core/Src/port.c ****     static const volatile uint8_t * const pcInterruptPriorityRegisters = ( const volatile uint8_t *
 189:Core/Src/port.c **** #endif /* configASSERT_DEFINED */
 190:Core/Src/port.c **** 
 191:Core/Src/port.c **** /*-----------------------------------------------------------*/
 192:Core/Src/port.c **** 
 193:Core/Src/port.c **** /*
 194:Core/Src/port.c ****  * See header file for description.
 195:Core/Src/port.c ****  */
 196:Core/Src/port.c **** StackType_t * pxPortInitialiseStack( StackType_t * pxTopOfStack,
 197:Core/Src/port.c ****                                      TaskFunction_t pxCode,
 198:Core/Src/port.c ****                                      void * pvParameters )
 199:Core/Src/port.c **** {
 200:Core/Src/port.c ****     /* Simulate the stack frame as it would be created by a context switch
 201:Core/Src/port.c ****      * interrupt. */
 202:Core/Src/port.c **** 
ARM GAS  /tmp/cc8ky6Wn.s 			page 5


 203:Core/Src/port.c ****     /* Offset added to account for the way the MCU uses the stack on entry/exit
 204:Core/Src/port.c ****      * of interrupts, and to ensure alignment. */
 205:Core/Src/port.c ****     pxTopOfStack--;
 206:Core/Src/port.c **** 
 207:Core/Src/port.c ****     *pxTopOfStack = portINITIAL_XPSR;                                    /* xPSR */
 208:Core/Src/port.c ****     pxTopOfStack--;
 209:Core/Src/port.c ****     *pxTopOfStack = ( ( StackType_t ) pxCode ) & portSTART_ADDRESS_MASK; /* PC */
 210:Core/Src/port.c ****     pxTopOfStack--;
 211:Core/Src/port.c ****     *pxTopOfStack = ( StackType_t ) portTASK_RETURN_ADDRESS;             /* LR */
 212:Core/Src/port.c **** 
 213:Core/Src/port.c ****     /* Save code space by skipping register initialisation. */
 214:Core/Src/port.c ****     pxTopOfStack -= 5;                            /* R12, R3, R2 and R1. */
 215:Core/Src/port.c ****     *pxTopOfStack = ( StackType_t ) pvParameters; /* R0 */
 216:Core/Src/port.c **** 
 217:Core/Src/port.c ****     /* A save method is being used that requires each task to maintain its
 218:Core/Src/port.c ****      * own exec return value. */
 219:Core/Src/port.c ****     pxTopOfStack--;
 220:Core/Src/port.c ****     *pxTopOfStack = portINITIAL_EXC_RETURN;
 221:Core/Src/port.c **** 
 222:Core/Src/port.c ****     pxTopOfStack -= 8; /* R11, R10, R9, R8, R7, R6, R5 and R4. */
 223:Core/Src/port.c **** 
 224:Core/Src/port.c ****     return pxTopOfStack;
 225:Core/Src/port.c **** }
 226:Core/Src/port.c **** /*-----------------------------------------------------------*/
 227:Core/Src/port.c **** 
 228:Core/Src/port.c **** static void prvTaskExitError( void )
 229:Core/Src/port.c **** {
 230:Core/Src/port.c ****     volatile uint32_t ulDummy = 0;
 231:Core/Src/port.c **** 
 232:Core/Src/port.c ****     /* A function that implements a task must not exit or attempt to return to
 233:Core/Src/port.c ****      * its caller as there is nothing to return to.  If a task wants to exit it
 234:Core/Src/port.c ****      * should instead call vTaskDelete( NULL ).
 235:Core/Src/port.c ****      *
 236:Core/Src/port.c ****      * Artificially force an assert() to be triggered if configASSERT() is
 237:Core/Src/port.c ****      * defined, then stop here so application writers can catch the error. */
 238:Core/Src/port.c ****     configASSERT( uxCriticalNesting == ~0UL );
 239:Core/Src/port.c ****     portDISABLE_INTERRUPTS();
 240:Core/Src/port.c **** 
 241:Core/Src/port.c ****     while( ulDummy == 0 )
 242:Core/Src/port.c ****     {
 243:Core/Src/port.c ****         /* This file calls prvTaskExitError() after the scheduler has been
 244:Core/Src/port.c ****          * started to remove a compiler warning about the function being defined
 245:Core/Src/port.c ****          * but never called.  ulDummy is used purely to quieten other warnings
 246:Core/Src/port.c ****          * about code appearing after this function is called - making ulDummy
 247:Core/Src/port.c ****          * volatile makes the compiler think the function could return and
 248:Core/Src/port.c ****          * therefore not output an 'unreachable code' warning for code that appears
 249:Core/Src/port.c ****          * after it. */
 250:Core/Src/port.c ****     }
 251:Core/Src/port.c **** }
 252:Core/Src/port.c **** /*-----------------------------------------------------------*/
