7226:../Core/FreeRTOS-Kernel/tasks.c ****         /*
7227:../Core/FreeRTOS-Kernel/tasks.c ****          * PLEASE NOTE:
7228:../Core/FreeRTOS-Kernel/tasks.c ****          *
7229:../Core/FreeRTOS-Kernel/tasks.c ****          * This function is provided for convenience only, and is used by many
7230:../Core/FreeRTOS-Kernel/tasks.c ****          * of the demo applications.  Do not consider it to be part of the
7231:../Core/FreeRTOS-Kernel/tasks.c ****          * scheduler.
7232:../Core/FreeRTOS-Kernel/tasks.c ****          *
7233:../Core/FreeRTOS-Kernel/tasks.c ****          * vTaskListTasks() calls uxTaskGetSystemState(), then formats part of the
7234:../Core/FreeRTOS-Kernel/tasks.c ****          * uxTaskGetSystemState() output into a human readable table that
7235:../Core/FreeRTOS-Kernel/tasks.c ****          * displays task: names, states, priority, stack usage and task number.
7236:../Core/FreeRTOS-Kernel/tasks.c ****          * Stack usage specified as the number of unused StackType_t words stack can hold
7237:../Core/FreeRTOS-Kernel/tasks.c ****          * on top of stack - not the number of bytes.
7238:../Core/FreeRTOS-Kernel/tasks.c ****          *
7239:../Core/FreeRTOS-Kernel/tasks.c ****          * vTaskListTasks() has a dependency on the snprintf() C library function that
7240:../Core/FreeRTOS-Kernel/tasks.c ****          * might bloat the code size, use a lot of stack, and provide different
7241:../Core/FreeRTOS-Kernel/tasks.c ****          * results on different platforms.  An alternative, tiny, third party,
7242:../Core/FreeRTOS-Kernel/tasks.c ****          * and limited functionality implementation of snprintf() is provided in
7243:../Core/FreeRTOS-Kernel/tasks.c ****          * many of the FreeRTOS/Demo sub-directories in a file called
7244:../Core/FreeRTOS-Kernel/tasks.c ****          * printf-stdarg.c (note printf-stdarg.c does not provide a full
7245:../Core/FreeRTOS-Kernel/tasks.c ****          * snprintf() implementation!).
7246:../Core/FreeRTOS-Kernel/tasks.c ****          *
7247:../Core/FreeRTOS-Kernel/tasks.c ****          * It is recommended that production systems call uxTaskGetSystemState()
7248:../Core/FreeRTOS-Kernel/tasks.c ****          * directly to get access to raw stats data, rather than indirectly
7249:../Core/FreeRTOS-Kernel/tasks.c ****          * through a call to vTaskListTasks().
7250:../Core/FreeRTOS-Kernel/tasks.c ****          */
7251:../Core/FreeRTOS-Kernel/tasks.c **** 
7252:../Core/FreeRTOS-Kernel/tasks.c **** 
7253:../Core/FreeRTOS-Kernel/tasks.c ****         /* Make sure the write buffer does not contain a string. */
7254:../Core/FreeRTOS-Kernel/tasks.c ****         *pcWriteBuffer = ( char ) 0x00;
7255:../Core/FreeRTOS-Kernel/tasks.c **** 
7256:../Core/FreeRTOS-Kernel/tasks.c ****         /* Take a snapshot of the number of tasks in case it changes while this
