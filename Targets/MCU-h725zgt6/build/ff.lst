3904:../../Extensions/fatfs//src/ff.c **** 					{
3905:../../Extensions/fatfs//src/ff.c **** 						fs->cdir = ld_clust(fs, dj.dir);					/* Sub-directory cluster */
3906:../../Extensions/fatfs//src/ff.c **** 					}
3907:../../Extensions/fatfs//src/ff.c **** 				} else {
3908:../../Extensions/fatfs//src/ff.c **** 					res = FR_NO_PATH;		/* Reached but a file */
3909:../../Extensions/fatfs//src/ff.c **** 				}
3910:../../Extensions/fatfs//src/ff.c **** 			}
3911:../../Extensions/fatfs//src/ff.c **** 		}
3912:../../Extensions/fatfs//src/ff.c **** 		FREE_NAMBUF();
3913:../../Extensions/fatfs//src/ff.c **** 		if (res == FR_NO_FILE) res = FR_NO_PATH;
3914:../../Extensions/fatfs//src/ff.c **** 	}
3915:../../Extensions/fatfs//src/ff.c **** 
3916:../../Extensions/fatfs//src/ff.c **** 	LEAVE_FF(fs, res);
3917:../../Extensions/fatfs//src/ff.c **** }
