 139:../Core/Src/fatfs_sd.c **** /* receive data block */
 140:../Core/Src/fatfs_sd.c **** static bool SD_RxDataBlock(BYTE *buff, UINT len)
 141:../Core/Src/fatfs_sd.c **** {
 142:../Core/Src/fatfs_sd.c **** 	uint8_t token;
 143:../Core/Src/fatfs_sd.c **** 
 144:../Core/Src/fatfs_sd.c **** 	/* timeout 200ms */
 145:../Core/Src/fatfs_sd.c **** 	Timer1 = HAL_GetTick() + 200;
 146:../Core/Src/fatfs_sd.c **** 
 147:../Core/Src/fatfs_sd.c **** 	/* loop until receive a response or timeout */
 148:../Core/Src/fatfs_sd.c **** 	do {
 149:../Core/Src/fatfs_sd.c **** 		token = SPI_RxByte();
 150:../Core/Src/fatfs_sd.c **** 	} while((token == 0xFF) && HAL_GetTick() < Timer1);
ARM GAS  /tmp/ccV1y3Jk.s 			page 14


 151:../Core/Src/fatfs_sd.c **** 
 152:../Core/Src/fatfs_sd.c **** 	/* invalid response */
 153:../Core/Src/fatfs_sd.c **** 	if(token != 0xFE) return FALSE;
 154:../Core/Src/fatfs_sd.c **** 
 155:../Core/Src/fatfs_sd.c **** 	/* receive data */
 156:../Core/Src/fatfs_sd.c **** 	do {
 157:../Core/Src/fatfs_sd.c **** 		SPI_RxBytePtr(buff++);
 158:../Core/Src/fatfs_sd.c **** 	} while(len--);
 159:../Core/Src/fatfs_sd.c **** 
 160:../Core/Src/fatfs_sd.c **** 	/* discard CRC */
 161:../Core/Src/fatfs_sd.c **** 	SPI_RxByte();
 162:../Core/Src/fatfs_sd.c **** 	SPI_RxByte();
 163:../Core/Src/fatfs_sd.c **** 
 164:../Core/Src/fatfs_sd.c **** 	return TRUE;
 165:../Core/Src/fatfs_sd.c **** }
 166:../Core/Src/fatfs_sd.c **** 
 167:../Core/Src/fatfs_sd.c **** /* transmit data block */
 168:../Core/Src/fatfs_sd.c **** #if _USE_WRITE == 1
 169:../Core/Src/fatfs_sd.c **** static bool SD_TxDataBlock(const uint8_t *buff, BYTE token)
 170:../Core/Src/fatfs_sd.c **** {
 171:../Core/Src/fatfs_sd.c **** 	uint8_t resp;
 172:../Core/Src/fatfs_sd.c **** 	uint8_t i = 0;
 173:../Core/Src/fatfs_sd.c **** 
 174:../Core/Src/fatfs_sd.c **** 	/* wait SD ready */
 175:../Core/Src/fatfs_sd.c **** 	if (SD_ReadyWait() != 0xFF) return FALSE;
 176:../Core/Src/fatfs_sd.c **** 
 177:../Core/Src/fatfs_sd.c **** 	/* transmit token */
 178:../Core/Src/fatfs_sd.c **** 	SPI_TxByte(token);
 179:../Core/Src/fatfs_sd.c **** 
 180:../Core/Src/fatfs_sd.c **** 	/* if it's not STOP token, transmit data */
 181:../Core/Src/fatfs_sd.c **** 	if (token != 0xFD)
 182:../Core/Src/fatfs_sd.c **** 	{
 183:../Core/Src/fatfs_sd.c **** 		SPI_TxBuffer((uint8_t*)buff, 512);
 184:../Core/Src/fatfs_sd.c **** 
 185:../Core/Src/fatfs_sd.c **** 		/* discard CRC */
 186:../Core/Src/fatfs_sd.c **** 		SPI_RxByte();
 187:../Core/Src/fatfs_sd.c **** 		SPI_RxByte();
 188:../Core/Src/fatfs_sd.c **** 
 189:../Core/Src/fatfs_sd.c **** 		/* receive response */
 190:../Core/Src/fatfs_sd.c **** 		while (i <= 64)
 191:../Core/Src/fatfs_sd.c **** 		{
 192:../Core/Src/fatfs_sd.c **** 			resp = SPI_RxByte();
 193:../Core/Src/fatfs_sd.c **** 
 194:../Core/Src/fatfs_sd.c **** 			/* transmit 0x05 accepted */
 195:../Core/Src/fatfs_sd.c **** 			if ((resp & 0x1F) == 0x05) break;
 196:../Core/Src/fatfs_sd.c **** 			i++;
 197:../Core/Src/fatfs_sd.c **** 		}
 198:../Core/Src/fatfs_sd.c **** 
 199:../Core/Src/fatfs_sd.c **** 		/* recv buffer clear */
 200:../Core/Src/fatfs_sd.c **** 		while (SPI_RxByte() == 0);
 201:../Core/Src/fatfs_sd.c **** 	}
 202:../Core/Src/fatfs_sd.c **** 
 203:../Core/Src/fatfs_sd.c **** 	/* transmit 0x05 accepted */
 204:../Core/Src/fatfs_sd.c **** 	if ((resp & 0x1F) == 0x05) return TRUE;
 205:../Core/Src/fatfs_sd.c **** 
 206:../Core/Src/fatfs_sd.c **** 	return FALSE;
 207:../Core/Src/fatfs_sd.c **** }
