3921:../../Extensions/fatfs//src/ff.c **** FRESULT f_getcwd (
3922:../../Extensions/fatfs//src/ff.c **** 	TCHAR* buff,	/* Pointer to the directory path */
3923:../../Extensions/fatfs//src/ff.c **** 	UINT len		/* Size of path */
3924:../../Extensions/fatfs//src/ff.c **** )
3925:../../Extensions/fatfs//src/ff.c **** {
3926:../../Extensions/fatfs//src/ff.c **** 	FRESULT res;
3927:../../Extensions/fatfs//src/ff.c **** 	DIR dj;
3928:../../Extensions/fatfs//src/ff.c **** 	FATFS *fs;
3929:../../Extensions/fatfs//src/ff.c **** 	UINT i, n;
