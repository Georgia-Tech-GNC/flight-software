2830:../../Extensions/fatfs//src/ff.c **** 		while (*path == '/' || *path == '\\') path++;	/* Strip heading separator */
2831:../../Extensions/fatfs//src/ff.c **** 		obj->sclust = 0;					/* Start from root directory */
2832:../../Extensions/fatfs//src/ff.c **** 	}
2833:../../Extensions/fatfs//src/ff.c **** #if _FS_EXFAT
2834:../../Extensions/fatfs//src/ff.c **** 	obj->n_frag = 0;	/* Invalidate last fragment counter of the object */
2835:../../Extensions/fatfs//src/ff.c **** #if _FS_RPATH != 0
2836:../../Extensions/fatfs//src/ff.c **** 	if (fs->fs_type == FS_EXFAT && obj->sclust) {	/* Retrieve the sub-directory status if needed */
2837:../../Extensions/fatfs//src/ff.c **** 		DIR dj;
2838:../../Extensions/fatfs//src/ff.c **** 
2839:../../Extensions/fatfs//src/ff.c **** 		obj->c_scl = fs->cdc_scl;
