  49:Core/Inc/portmacro.h **** /* Type definitions. */
  50:Core/Inc/portmacro.h **** #define portCHAR          char
  51:Core/Inc/portmacro.h **** #define portFLOAT         float
  52:Core/Inc/portmacro.h **** #define portDOUBLE        double
  53:Core/Inc/portmacro.h **** #define portLONG          long
  54:Core/Inc/portmacro.h **** #define portSHORT         short
  55:Core/Inc/portmacro.h **** #define portSTACK_TYPE    uint32_t
  56:Core/Inc/portmacro.h **** #define portBASE_TYPE     long
  57:Core/Inc/portmacro.h **** 
  58:Core/Inc/portmacro.h **** typedef portSTACK_TYPE   StackType_t;
  59:Core/Inc/portmacro.h **** typedef long             BaseType_t;
  60:Core/Inc/portmacro.h **** typedef unsigned long    UBaseType_t;
  61:Core/Inc/portmacro.h **** 
  62:Core/Inc/portmacro.h **** #if ( configTICK_TYPE_WIDTH_IN_BITS == TICK_TYPE_WIDTH_16_BITS )
