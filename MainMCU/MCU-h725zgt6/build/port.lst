 857:Core/Src/port.c ****             /* The following assertion will fail if a service routine (ISR) for
 858:Core/Src/port.c ****              * an interrupt that has been assigned a priority above
 859:Core/Src/port.c ****              * configMAX_SYSCALL_INTERRUPT_PRIORITY calls an ISR safe FreeRTOS API
 860:Core/Src/port.c ****              * function.  ISR safe FreeRTOS API functions must *only* be called
 861:Core/Src/port.c ****              * from interrupts that have been assigned a priority at or below
 862:Core/Src/port.c ****              * configMAX_SYSCALL_INTERRUPT_PRIORITY.
 863:Core/Src/port.c ****              *
 864:Core/Src/port.c ****              * Numerically low interrupt priority numbers represent logically high
 865:Core/Src/port.c ****              * interrupt priorities, therefore the priority of the interrupt must
 866:Core/Src/port.c ****              * be set to a value equal to or numerically *higher* than
 867:Core/Src/port.c ****              * configMAX_SYSCALL_INTERRUPT_PRIORITY.
 868:Core/Src/port.c ****              *
 869:Core/Src/port.c ****              * Interrupts that  use the FreeRTOS API must not be left at their
 870:Core/Src/port.c ****              * default priority of  zero as that is the highest possible priority,
 871:Core/Src/port.c ****              * which is guaranteed to be above configMAX_SYSCALL_INTERRUPT_PRIORITY,
 872:Core/Src/port.c ****              * and  therefore also guaranteed to be invalid.
 873:Core/Src/port.c ****              *
 874:Core/Src/port.c ****              * FreeRTOS maintains separate thread and ISR API functions to ensure
 875:Core/Src/port.c ****              * interrupt entry is as fast and simple as possible.
 876:Core/Src/port.c ****              *
 877:Core/Src/port.c ****              * The following links provide detailed information:
 878:Core/Src/port.c ****              * https://www.FreeRTOS.org/RTOS-Cortex-M3-M4.html
 879:Core/Src/port.c ****              * https://www.FreeRTOS.org/FAQHelp.html */
 880:Core/Src/port.c ****             configASSERT( ucCurrentPriority >= ucMaxSysCallPriority );
