2015:../../Extensions/fatfs//src/ff.c **** 	/* Sanity check (do it when accessible object name) */
2016:../../Extensions/fatfs//src/ff.c **** 	if (i <= MAXDIRB(_MAX_LFN)) {
2017:../../Extensions/fatfs//src/ff.c **** 		if (xdir_sum(dirb) != ld_word(dirb + XDIR_SetSum)) return FR_INT_ERR;
2018:../../Extensions/fatfs//src/ff.c **** 	}
2019:../../Extensions/fatfs//src/ff.c **** 	return FR_OK;
