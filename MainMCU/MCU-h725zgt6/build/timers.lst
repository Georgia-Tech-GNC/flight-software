 100:../Core/FreeRTOS-Kernel/timers.c **** /* The definition of messages that can be sent and received on the timer queue.
 101:../Core/FreeRTOS-Kernel/timers.c ****  * Two types of message can be queued - messages that manipulate a software timer,
 102:../Core/FreeRTOS-Kernel/timers.c ****  * and messages that request the execution of a non-timer related callback.  The
 103:../Core/FreeRTOS-Kernel/timers.c ****  * two message types are defined in two separate structures, xTimerParametersType
 104:../Core/FreeRTOS-Kernel/timers.c ****  * and xCallbackParametersType respectively. */
 105:../Core/FreeRTOS-Kernel/timers.c ****     typedef struct tmrTimerParameters
 106:../Core/FreeRTOS-Kernel/timers.c ****     {
 107:../Core/FreeRTOS-Kernel/timers.c ****         TickType_t xMessageValue; /**< An optional value used by a subset of commands, for example,
 108:../Core/FreeRTOS-Kernel/timers.c ****         Timer_t * pxTimer;        /**< The timer to which the command will be applied. */
 109:../Core/FreeRTOS-Kernel/timers.c ****     } TimerParameter_t;
 110:../Core/FreeRTOS-Kernel/timers.c **** 
 111:../Core/FreeRTOS-Kernel/timers.c **** 
 112:../Core/FreeRTOS-Kernel/timers.c ****     typedef struct tmrCallbackParameters
 113:../Core/FreeRTOS-Kernel/timers.c ****     {
 114:../Core/FreeRTOS-Kernel/timers.c ****         portTIMER_CALLBACK_ATTRIBUTE
 115:../Core/FreeRTOS-Kernel/timers.c ****         PendedFunction_t pxCallbackFunction; /* << The callback function to execute. */
 116:../Core/FreeRTOS-Kernel/timers.c ****         void * pvParameter1;                 /* << The value that will be used as the callback func
 117:../Core/FreeRTOS-Kernel/timers.c ****         uint32_t ulParameter2;               /* << The value that will be used as the callback func
 118:../Core/FreeRTOS-Kernel/timers.c ****     } CallbackParameters_t;
 119:../Core/FreeRTOS-Kernel/timers.c **** 
 120:../Core/FreeRTOS-Kernel/timers.c **** /* The structure that contains the two message types, along with an identifier
 121:../Core/FreeRTOS-Kernel/timers.c ****  * that is used to determine which message type is valid. */
 122:../Core/FreeRTOS-Kernel/timers.c ****     typedef struct tmrTimerQueueMessage
 123:../Core/FreeRTOS-Kernel/timers.c ****     {
 124:../Core/FreeRTOS-Kernel/timers.c ****         BaseType_t xMessageID; /**< The command being sent to the timer service task. */
 125:../Core/FreeRTOS-Kernel/timers.c ****         union
 126:../Core/FreeRTOS-Kernel/timers.c ****         {
 127:../Core/FreeRTOS-Kernel/timers.c ****             TimerParameter_t xTimerParameters;
 128:../Core/FreeRTOS-Kernel/timers.c **** 
 129:../Core/FreeRTOS-Kernel/timers.c ****             /* Don't include xCallbackParameters if it is not going to be used as
 130:../Core/FreeRTOS-Kernel/timers.c ****              * it makes the structure (and therefore the timer queue) larger. */
 131:../Core/FreeRTOS-Kernel/timers.c ****             #if ( INCLUDE_xTimerPendFunctionCall == 1 )
 132:../Core/FreeRTOS-Kernel/timers.c ****                 CallbackParameters_t xCallbackParameters;
 133:../Core/FreeRTOS-Kernel/timers.c ****             #endif /* INCLUDE_xTimerPendFunctionCall */
 134:../Core/FreeRTOS-Kernel/timers.c ****         } u;
 135:../Core/FreeRTOS-Kernel/timers.c ****     } DaemonTaskMessage_t;
 136:../Core/FreeRTOS-Kernel/timers.c **** 
 137:../Core/FreeRTOS-Kernel/timers.c **** /* The list in which active timers are stored.  Timers are referenced in expire
 138:../Core/FreeRTOS-Kernel/timers.c ****  * time order, with the nearest expiry time at the front of the list.  Only the
 139:../Core/FreeRTOS-Kernel/timers.c ****  * timer service task is allowed to access these lists.
 140:../Core/FreeRTOS-Kernel/timers.c ****  * xActiveTimerList1 and xActiveTimerList2 could be at function scope but that
 141:../Core/FreeRTOS-Kernel/timers.c ****  * breaks some kernel aware debuggers, and debuggers that reply on removing the
 142:../Core/FreeRTOS-Kernel/timers.c ****  * static qualifier. */
 143:../Core/FreeRTOS-Kernel/timers.c ****     PRIVILEGED_DATA static List_t xActiveTimerList1;
 144:../Core/FreeRTOS-Kernel/timers.c ****     PRIVILEGED_DATA static List_t xActiveTimerList2;
