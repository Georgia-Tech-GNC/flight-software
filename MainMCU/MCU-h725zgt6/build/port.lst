  99:Core/Inc/portmacro.h ****     do                                           \
 100:Core/Inc/portmacro.h ****     {                                            \
 101:Core/Inc/portmacro.h ****         if( xSwitchRequired != pdFALSE )         \
 102:Core/Inc/portmacro.h ****         {                                        \
 103:Core/Inc/portmacro.h ****             traceISR_EXIT_TO_SCHEDULER();        \
 104:Core/Inc/portmacro.h ****             portYIELD();                         \
 105:Core/Inc/portmacro.h ****         }                                        \
