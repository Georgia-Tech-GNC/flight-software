 460:../../Extensions/fatfs//src/ff.c **** #if _USE_LFN == 1
 461:../../Extensions/fatfs//src/ff.c **** #error Static LFN work area cannot be used at thread-safe configuration
 462:../../Extensions/fatfs//src/ff.c **** #endif
 463:../../Extensions/fatfs//src/ff.c **** #define	ENTER_FF(fs)		{ if (!lock_fs(fs)) return FR_TIMEOUT; }
 464:../../Extensions/fatfs//src/ff.c **** #define	LEAVE_FF(fs, res)	{ unlock_fs(fs, res); return res; }
 465:../../Extensions/fatfs//src/ff.c **** #else
 466:../../Extensions/fatfs//src/ff.c **** #define	ENTER_FF(fs)
 467:../../Extensions/fatfs//src/ff.c **** #define LEAVE_FF(fs, res)	return res
 468:../../Extensions/fatfs//src/ff.c **** #endif
