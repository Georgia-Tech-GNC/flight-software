5663:../Core/FreeRTOS-Kernel/tasks.c ****  * -----------------------------------------------------------
5664:../Core/FreeRTOS-Kernel/tasks.c ****  * The passive idle task.
5665:../Core/FreeRTOS-Kernel/tasks.c ****  * ----------------------------------------------------------
5666:../Core/FreeRTOS-Kernel/tasks.c ****  *
5667:../Core/FreeRTOS-Kernel/tasks.c ****  * The passive idle task is used for all the additional cores in a SMP
5668:../Core/FreeRTOS-Kernel/tasks.c ****  * system. There must be only 1 active idle task and the rest are passive
5669:../Core/FreeRTOS-Kernel/tasks.c ****  * idle tasks.
5670:../Core/FreeRTOS-Kernel/tasks.c ****  *
5671:../Core/FreeRTOS-Kernel/tasks.c ****  * The portTASK_FUNCTION() macro is used to allow port/compiler specific
ARM GAS  /tmp/ccAPAJwv.s 			page 103


5672:../Core/FreeRTOS-Kernel/tasks.c ****  * language extensions.  The equivalent prototype for this function is:
5673:../Core/FreeRTOS-Kernel/tasks.c ****  *
5674:../Core/FreeRTOS-Kernel/tasks.c ****  * void prvPassiveIdleTask( void *pvParameters );
5675:../Core/FreeRTOS-Kernel/tasks.c ****  */
5676:../Core/FreeRTOS-Kernel/tasks.c **** 
5677:../Core/FreeRTOS-Kernel/tasks.c **** #if ( configNUMBER_OF_CORES > 1 )
5678:../Core/FreeRTOS-Kernel/tasks.c ****     static portTASK_FUNCTION( prvPassiveIdleTask, pvParameters )
5679:../Core/FreeRTOS-Kernel/tasks.c ****     {
5680:../Core/FreeRTOS-Kernel/tasks.c ****         ( void ) pvParameters;
5681:../Core/FreeRTOS-Kernel/tasks.c **** 
5682:../Core/FreeRTOS-Kernel/tasks.c ****         taskYIELD();
5683:../Core/FreeRTOS-Kernel/tasks.c **** 
5684:../Core/FreeRTOS-Kernel/tasks.c ****         for( ; configCONTROL_INFINITE_LOOP(); )
5685:../Core/FreeRTOS-Kernel/tasks.c ****         {
5686:../Core/FreeRTOS-Kernel/tasks.c ****             #if ( configUSE_PREEMPTION == 0 )
5687:../Core/FreeRTOS-Kernel/tasks.c ****             {
5688:../Core/FreeRTOS-Kernel/tasks.c ****                 /* If we are not using preemption we keep forcing a task switch to
5689:../Core/FreeRTOS-Kernel/tasks.c ****                  * see if any other task has become available.  If we are using
5690:../Core/FreeRTOS-Kernel/tasks.c ****                  * preemption we don't need to do this as any task becoming available
5691:../Core/FreeRTOS-Kernel/tasks.c ****                  * will automatically get the processor anyway. */
5692:../Core/FreeRTOS-Kernel/tasks.c ****                 taskYIELD();
5693:../Core/FreeRTOS-Kernel/tasks.c ****             }
5694:../Core/FreeRTOS-Kernel/tasks.c ****             #endif /* configUSE_PREEMPTION */
5695:../Core/FreeRTOS-Kernel/tasks.c **** 
5696:../Core/FreeRTOS-Kernel/tasks.c ****             #if ( ( configUSE_PREEMPTION == 1 ) && ( configIDLE_SHOULD_YIELD == 1 ) )
5697:../Core/FreeRTOS-Kernel/tasks.c ****             {
5698:../Core/FreeRTOS-Kernel/tasks.c ****                 /* When using preemption tasks of equal priority will be
5699:../Core/FreeRTOS-Kernel/tasks.c ****                  * timesliced.  If a task that is sharing the idle priority is ready
5700:../Core/FreeRTOS-Kernel/tasks.c ****                  * to run then the idle task should yield before the end of the
5701:../Core/FreeRTOS-Kernel/tasks.c ****                  * timeslice.
5702:../Core/FreeRTOS-Kernel/tasks.c ****                  *
5703:../Core/FreeRTOS-Kernel/tasks.c ****                  * A critical region is not required here as we are just reading from
5704:../Core/FreeRTOS-Kernel/tasks.c ****                  * the list, and an occasional incorrect value will not matter.  If
5705:../Core/FreeRTOS-Kernel/tasks.c ****                  * the ready list at the idle priority contains one more task than the
5706:../Core/FreeRTOS-Kernel/tasks.c ****                  * number of idle tasks, which is equal to the configured numbers of cores
5707:../Core/FreeRTOS-Kernel/tasks.c ****                  * then a task other than the idle task is ready to execute. */
5708:../Core/FreeRTOS-Kernel/tasks.c ****                 if( listCURRENT_LIST_LENGTH( &( pxReadyTasksLists[ tskIDLE_PRIORITY ] ) ) > ( UBase
5709:../Core/FreeRTOS-Kernel/tasks.c ****                 {
5710:../Core/FreeRTOS-Kernel/tasks.c ****                     taskYIELD();
5711:../Core/FreeRTOS-Kernel/tasks.c ****                 }
5712:../Core/FreeRTOS-Kernel/tasks.c ****                 else
5713:../Core/FreeRTOS-Kernel/tasks.c ****                 {
5714:../Core/FreeRTOS-Kernel/tasks.c ****                     mtCOVERAGE_TEST_MARKER();
5715:../Core/FreeRTOS-Kernel/tasks.c ****                 }
