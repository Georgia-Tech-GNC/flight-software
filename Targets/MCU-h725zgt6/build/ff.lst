1985:../../Extensions/fatfs//src/ff.c **** 
1986:../../Extensions/fatfs//src/ff.c **** 
1987:../../Extensions/fatfs//src/ff.c **** 	/* Load 85 entry */
1988:../../Extensions/fatfs//src/ff.c **** 	res = move_window(dp->obj.fs, dp->sect);
1989:../../Extensions/fatfs//src/ff.c **** 	if (res != FR_OK) return res;
1990:../../Extensions/fatfs//src/ff.c **** 	if (dp->dir[XDIR_Type] != 0x85) return FR_INT_ERR;
1991:../../Extensions/fatfs//src/ff.c **** 	mem_cpy(dirb + 0, dp->dir, SZDIRE);
1992:../../Extensions/fatfs//src/ff.c **** 	sz_ent = (dirb[XDIR_NumSec] + 1) * SZDIRE;
1993:../../Extensions/fatfs//src/ff.c **** 	if (sz_ent < 3 * SZDIRE || sz_ent > 19 * SZDIRE) return FR_INT_ERR;
1994:../../Extensions/fatfs//src/ff.c **** 
1995:../../Extensions/fatfs//src/ff.c **** 	/* Load C0 entry */
1996:../../Extensions/fatfs//src/ff.c **** 	res = dir_next(dp, 0);
1997:../../Extensions/fatfs//src/ff.c **** 	if (res != FR_OK) return res;
1998:../../Extensions/fatfs//src/ff.c **** 	res = move_window(dp->obj.fs, dp->sect);
1999:../../Extensions/fatfs//src/ff.c **** 	if (res != FR_OK) return res;
2000:../../Extensions/fatfs//src/ff.c **** 	if (dp->dir[XDIR_Type] != 0xC0) return FR_INT_ERR;
2001:../../Extensions/fatfs//src/ff.c **** 	mem_cpy(dirb + SZDIRE, dp->dir, SZDIRE);
2002:../../Extensions/fatfs//src/ff.c **** 	if (MAXDIRB(dirb[XDIR_NumName]) > sz_ent) return FR_INT_ERR;
2003:../../Extensions/fatfs//src/ff.c **** 
2004:../../Extensions/fatfs//src/ff.c **** 	/* Load C1 entries */
2005:../../Extensions/fatfs//src/ff.c **** 	i = SZDIRE * 2;	/* C1 offset */
2006:../../Extensions/fatfs//src/ff.c **** 	do {
2007:../../Extensions/fatfs//src/ff.c **** 		res = dir_next(dp, 0);
2008:../../Extensions/fatfs//src/ff.c **** 		if (res != FR_OK) return res;
2009:../../Extensions/fatfs//src/ff.c **** 		res = move_window(dp->obj.fs, dp->sect);
2010:../../Extensions/fatfs//src/ff.c **** 		if (res != FR_OK) return res;
2011:../../Extensions/fatfs//src/ff.c **** 		if (dp->dir[XDIR_Type] != 0xC1) return FR_INT_ERR;
2012:../../Extensions/fatfs//src/ff.c **** 		if (i < MAXDIRB(_MAX_LFN)) mem_cpy(dirb + i, dp->dir, SZDIRE);
2013:../../Extensions/fatfs//src/ff.c **** 	} while ((i += SZDIRE) < sz_ent);
