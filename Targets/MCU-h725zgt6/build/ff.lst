1080:../../Extensions/fatfs//src/ff.c **** static
1081:../../Extensions/fatfs//src/ff.c **** FRESULT put_fat (	/* FR_OK(0):succeeded, !=0:error */
1082:../../Extensions/fatfs//src/ff.c **** 	FATFS* fs,		/* Corresponding file system object */
1083:../../Extensions/fatfs//src/ff.c **** 	DWORD clst,		/* FAT index number (cluster number) to be changed */
1084:../../Extensions/fatfs//src/ff.c **** 	DWORD val		/* New value to be set to the entry */
1085:../../Extensions/fatfs//src/ff.c **** )
1086:../../Extensions/fatfs//src/ff.c **** {
1087:../../Extensions/fatfs//src/ff.c **** 	UINT bc;
1088:../../Extensions/fatfs//src/ff.c **** 	BYTE *p;
1089:../../Extensions/fatfs//src/ff.c **** 	FRESULT res = FR_INT_ERR;
1090:../../Extensions/fatfs//src/ff.c **** 
1091:../../Extensions/fatfs//src/ff.c **** 	if (clst >= 2 && clst < fs->n_fatent) {	/* Check if in valid range */
1092:../../Extensions/fatfs//src/ff.c **** 		switch (fs->fs_type) {
1093:../../Extensions/fatfs//src/ff.c **** 		case FS_FAT12 :	/* Bitfield items */
1094:../../Extensions/fatfs//src/ff.c **** 			bc = (UINT)clst; bc += bc / 2;
1095:../../Extensions/fatfs//src/ff.c **** 			res = move_window(fs, fs->fatbase + (bc / SS(fs)));
1096:../../Extensions/fatfs//src/ff.c **** 			if (res != FR_OK) break;
1097:../../Extensions/fatfs//src/ff.c **** 			p = fs->win + bc++ % SS(fs);
1098:../../Extensions/fatfs//src/ff.c **** 			*p = (clst & 1) ? ((*p & 0x0F) | ((BYTE)val << 4)) : (BYTE)val;
1099:../../Extensions/fatfs//src/ff.c **** 			fs->wflag = 1;
1100:../../Extensions/fatfs//src/ff.c **** 			res = move_window(fs, fs->fatbase + (bc / SS(fs)));
1101:../../Extensions/fatfs//src/ff.c **** 			if (res != FR_OK) break;
1102:../../Extensions/fatfs//src/ff.c **** 			p = fs->win + bc % SS(fs);
1103:../../Extensions/fatfs//src/ff.c **** 			*p = (clst & 1) ? (BYTE)(val >> 4) : ((*p & 0xF0) | ((BYTE)(val >> 8) & 0x0F));
1104:../../Extensions/fatfs//src/ff.c **** 			fs->wflag = 1;
1105:../../Extensions/fatfs//src/ff.c **** 			break;
1106:../../Extensions/fatfs//src/ff.c **** 
1107:../../Extensions/fatfs//src/ff.c **** 		case FS_FAT16 :	/* WORD aligned items */
1108:../../Extensions/fatfs//src/ff.c **** 			res = move_window(fs, fs->fatbase + (clst / (SS(fs) / 2)));
1109:../../Extensions/fatfs//src/ff.c **** 			if (res != FR_OK) break;
1110:../../Extensions/fatfs//src/ff.c **** 			st_word(fs->win + clst * 2 % SS(fs), (WORD)val);
1111:../../Extensions/fatfs//src/ff.c **** 			fs->wflag = 1;
1112:../../Extensions/fatfs//src/ff.c **** 			break;
1113:../../Extensions/fatfs//src/ff.c **** 
1114:../../Extensions/fatfs//src/ff.c **** 		case FS_FAT32 :	/* DWORD aligned items */
1115:../../Extensions/fatfs//src/ff.c **** #if _FS_EXFAT
1116:../../Extensions/fatfs//src/ff.c **** 		case FS_EXFAT :
1117:../../Extensions/fatfs//src/ff.c **** #endif
1118:../../Extensions/fatfs//src/ff.c **** 			res = move_window(fs, fs->fatbase + (clst / (SS(fs) / 4)));
1119:../../Extensions/fatfs//src/ff.c **** 			if (res != FR_OK) break;
1120:../../Extensions/fatfs//src/ff.c **** 			if (!_FS_EXFAT || fs->fs_type != FS_EXFAT) {
1121:../../Extensions/fatfs//src/ff.c **** 				val = (val & 0x0FFFFFFF) | (ld_dword(fs->win + clst * 4 % SS(fs)) & 0xF0000000);
1122:../../Extensions/fatfs//src/ff.c **** 			}
