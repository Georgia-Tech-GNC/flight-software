 196:Core/Inc/portmacro.h ****     if( ulCurrentInterrupt == 0 )
 197:Core/Inc/portmacro.h ****     {
 198:Core/Inc/portmacro.h ****         xReturn = pdFALSE;
 199:Core/Inc/portmacro.h ****     }
 200:Core/Inc/portmacro.h ****     else
 201:Core/Inc/portmacro.h ****     {
 202:Core/Inc/portmacro.h ****         xReturn = pdTRUE;
 203:Core/Inc/portmacro.h ****     }
 204:Core/Inc/portmacro.h **** 
 205:Core/Inc/portmacro.h ****     return xReturn;
 206:Core/Inc/portmacro.h **** }
