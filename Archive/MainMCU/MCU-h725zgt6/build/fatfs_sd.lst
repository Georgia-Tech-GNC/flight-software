 139:../Core/Src/fatfs_sd.c **** /* receive data block */
 140:../Core/Src/fatfs_sd.c **** static bool SD_RxDataBlock(BYTE *buff, UINT len)
 141:../Core/Src/fatfs_sd.c **** {
 142:../Core/Src/fatfs_sd.c **** 	uint8_t token;
 143:../Core/Src/fatfs_sd.c **** 
 144:../Core/Src/fatfs_sd.c **** 	/* timeout 200ms */
 145:../Core/Src/fatfs_sd.c **** 	Timer1 = HAL_GetTick() + 200;
 146:../Core/Src/fatfs_sd.c **** 
 147:../Core/Src/fatfs_sd.c **** 	/* loop until receive a response or timeout */
 148:../Core/Src/fatfs_sd.c **** 	do {
 149:../Core/Src/fatfs_sd.c **** 		token = SPI_RxByte();
 150:../Core/Src/fatfs_sd.c **** 	} while((token == 0xFF) && HAL_GetTick() < Timer1);
 151:../Core/Src/fatfs_sd.c **** 
 152:../Core/Src/fatfs_sd.c **** 	/* invalid response */
 153:../Core/Src/fatfs_sd.c **** 	if(token != 0xFE) return FALSE;
 154:../Core/Src/fatfs_sd.c **** 
 155:../Core/Src/fatfs_sd.c **** 	/* receive data */
 156:../Core/Src/fatfs_sd.c **** 	do {
 157:../Core/Src/fatfs_sd.c **** 		SPI_RxBytePtr(buff++);
 158:../Core/Src/fatfs_sd.c **** 	} while(len--);
 159:../Core/Src/fatfs_sd.c **** 
 160:../Core/Src/fatfs_sd.c **** 	/* discard CRC */
 161:../Core/Src/fatfs_sd.c **** 	SPI_RxByte();
 162:../Core/Src/fatfs_sd.c **** 	SPI_RxByte();
 163:../Core/Src/fatfs_sd.c **** 
 164:../Core/Src/fatfs_sd.c **** 	return TRUE;
 165:../Core/Src/fatfs_sd.c **** }
