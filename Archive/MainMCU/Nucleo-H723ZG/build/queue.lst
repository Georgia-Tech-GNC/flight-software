  48:Core/Inc/portmacro.h **** 
  49:Core/Inc/portmacro.h **** /* Type definitions. */
  50:Core/Inc/portmacro.h **** #define portCHAR          char
  51:Core/Inc/portmacro.h **** #define portFLOAT         float
  52:Core/Inc/portmacro.h **** #define portDOUBLE        double
  53:Core/Inc/portmacro.h **** #define portLONG          long
  54:Core/Inc/portmacro.h **** #define portSHORT         short
  55:Core/Inc/portmacro.h **** #define portSTACK_TYPE    uint32_t
  56:Core/Inc/portmacro.h **** #define portBASE_TYPE     long
  57:Core/Inc/portmacro.h **** 
  58:Core/Inc/portmacro.h **** typedef portSTACK_TYPE   StackType_t;
  59:Core/Inc/portmacro.h **** typedef long             BaseType_t;
  60:Core/Inc/portmacro.h **** typedef unsigned long    UBaseType_t;
  61:Core/Inc/portmacro.h **** 
  62:Core/Inc/portmacro.h **** #if ( configTICK_TYPE_WIDTH_IN_BITS == TICK_TYPE_WIDTH_16_BITS )
  63:Core/Inc/portmacro.h ****     typedef uint16_t     TickType_t;
  64:Core/Inc/portmacro.h ****     #define portMAX_DELAY              ( TickType_t ) 0xffff
  65:Core/Inc/portmacro.h **** #elif ( configTICK_TYPE_WIDTH_IN_BITS == TICK_TYPE_WIDTH_32_BITS )
  66:Core/Inc/portmacro.h ****     typedef uint32_t     TickType_t;
  67:Core/Inc/portmacro.h ****     #define portMAX_DELAY              ( TickType_t ) 0xffffffffUL
  68:Core/Inc/portmacro.h **** 
  69:Core/Inc/portmacro.h **** /* 32-bit tick type on a 32-bit architecture, so reads of the tick count do
  70:Core/Inc/portmacro.h ****  * not need to be guarded with a critical section. */
  71:Core/Inc/portmacro.h ****     #define portTICK_TYPE_IS_ATOMIC    1
  72:Core/Inc/portmacro.h **** #else
  73:Core/Inc/portmacro.h ****     #error configTICK_TYPE_WIDTH_IN_BITS set to unsupported tick type width.
  74:Core/Inc/portmacro.h **** #endif
