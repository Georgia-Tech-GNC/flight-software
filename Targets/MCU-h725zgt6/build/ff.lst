1187:../../Extensions/fatfs//src/ff.c **** FRESULT change_bitmap (
1188:../../Extensions/fatfs//src/ff.c **** 	FATFS* fs,	/* File system object */
1189:../../Extensions/fatfs//src/ff.c **** 	DWORD clst,	/* Cluster number to change from */
1190:../../Extensions/fatfs//src/ff.c **** 	DWORD ncl,	/* Number of clusters to be changed */
1191:../../Extensions/fatfs//src/ff.c **** 	int bv		/* bit value to be set (0 or 1) */
1192:../../Extensions/fatfs//src/ff.c **** )
1193:../../Extensions/fatfs//src/ff.c **** {
1194:../../Extensions/fatfs//src/ff.c **** 	BYTE bm;
1195:../../Extensions/fatfs//src/ff.c **** 	UINT i;
1196:../../Extensions/fatfs//src/ff.c **** 	DWORD sect;
1197:../../Extensions/fatfs//src/ff.c **** 
1198:../../Extensions/fatfs//src/ff.c **** 	clst -= 2;	/* The first bit corresponds to cluster #2 */
1199:../../Extensions/fatfs//src/ff.c **** 	sect = fs->database + clst / 8 / SS(fs);	/* Sector address (assuming bitmap is located top of the 
1200:../../Extensions/fatfs//src/ff.c **** 	i = clst / 8 % SS(fs);						/* Byte offset in the sector */
1201:../../Extensions/fatfs//src/ff.c **** 	bm = 1 << (clst % 8);						/* Bit mask in the byte */
1202:../../Extensions/fatfs//src/ff.c **** 	for (;;) {
1203:../../Extensions/fatfs//src/ff.c **** 		if (move_window(fs, sect++) != FR_OK) return FR_DISK_ERR;
1204:../../Extensions/fatfs//src/ff.c **** 		do {
1205:../../Extensions/fatfs//src/ff.c **** 			do {
1206:../../Extensions/fatfs//src/ff.c **** 				if (bv == (int)((fs->win[i] & bm) != 0)) return FR_INT_ERR;	/* Is the bit expected value? */
1207:../../Extensions/fatfs//src/ff.c **** 				fs->win[i] ^= bm;	/* Flip the bit */
1208:../../Extensions/fatfs//src/ff.c **** 				fs->wflag = 1;
1209:../../Extensions/fatfs//src/ff.c **** 				if (--ncl == 0) return FR_OK;	/* All bits processed? */
1210:../../Extensions/fatfs//src/ff.c **** 			} while (bm <<= 1);		/* Next bit */
1211:../../Extensions/fatfs//src/ff.c **** 			bm = 1;
1212:../../Extensions/fatfs//src/ff.c **** 		} while (++i < SS(fs));		/* Next byte */
1213:../../Extensions/fatfs//src/ff.c **** 		i = 0;
1214:../../Extensions/fatfs//src/ff.c **** 	}
1215:../../Extensions/fatfs//src/ff.c **** }
