 463:Core/Src/port.c **** 
 464:Core/Src/port.c **** void vPortEnterCritical( void )
 465:Core/Src/port.c **** {
 466:Core/Src/port.c ****     portDISABLE_INTERRUPTS();
 467:Core/Src/port.c ****     uxCriticalNesting++;
 468:Core/Src/port.c **** 
 469:Core/Src/port.c ****     /* This is not the interrupt safe version of the enter critical function so
 470:Core/Src/port.c ****      * assert() if it is being called from an interrupt context.  Only API
 471:Core/Src/port.c ****      * functions that end in "FromISR" can be used in an interrupt.  Only assert if
ARM GAS  /tmp/cc8ky6Wn.s 			page 11


 472:Core/Src/port.c ****      * the critical nesting count is 1 to protect against recursive calls if the
 473:Core/Src/port.c ****      * assert function also uses a critical section. */
 474:Core/Src/port.c ****     if( uxCriticalNesting == 1 )
 475:Core/Src/port.c ****     {
 476:Core/Src/port.c ****         configASSERT( ( portNVIC_INT_CTRL_REG & portVECTACTIVE_MASK ) == 0 );
 477:Core/Src/port.c ****     }
 478:Core/Src/port.c **** }
 479:Core/Src/port.c **** /*-----------------------------------------------------------*/
 480:Core/Src/port.c **** 
 481:Core/Src/port.c **** void vPortExitCritical( void )
 482:Core/Src/port.c **** {
 483:Core/Src/port.c ****     configASSERT( uxCriticalNesting );
 484:Core/Src/port.c ****     uxCriticalNesting--;
 485:Core/Src/port.c **** 
 486:Core/Src/port.c ****     if( uxCriticalNesting == 0 )
 487:Core/Src/port.c ****     {
 488:Core/Src/port.c ****         portENABLE_INTERRUPTS();
 489:Core/Src/port.c ****     }
 490:Core/Src/port.c **** }
