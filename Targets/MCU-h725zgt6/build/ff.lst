1867:../../Extensions/fatfs//src/ff.c **** /* exFAT: Checksum                                                       */
1868:../../Extensions/fatfs//src/ff.c **** /*-----------------------------------------------------------------------*/
1869:../../Extensions/fatfs//src/ff.c **** 
1870:../../Extensions/fatfs//src/ff.c **** static
1871:../../Extensions/fatfs//src/ff.c **** WORD xdir_sum (			/* Get checksum of the directoly block */
1872:../../Extensions/fatfs//src/ff.c **** 	const BYTE* dir		/* Directory entry block to be calculated */
1873:../../Extensions/fatfs//src/ff.c **** )
1874:../../Extensions/fatfs//src/ff.c **** {
1875:../../Extensions/fatfs//src/ff.c **** 	UINT i, szblk;
1876:../../Extensions/fatfs//src/ff.c **** 	WORD sum;
1877:../../Extensions/fatfs//src/ff.c **** 
1878:../../Extensions/fatfs//src/ff.c **** 
1879:../../Extensions/fatfs//src/ff.c **** 	szblk = (dir[XDIR_NumSec] + 1) * SZDIRE;
1880:../../Extensions/fatfs//src/ff.c **** 	for (i = sum = 0; i < szblk; i++) {
1881:../../Extensions/fatfs//src/ff.c **** 		if (i == XDIR_SetSum) {	/* Skip sum field */
1882:../../Extensions/fatfs//src/ff.c **** 			i++;
1883:../../Extensions/fatfs//src/ff.c **** 		} else {
1884:../../Extensions/fatfs//src/ff.c **** 			sum = ((sum & 1) ? 0x8000 : 0) + (sum >> 1) + dir[i];
1885:../../Extensions/fatfs//src/ff.c **** 		}
1886:../../Extensions/fatfs//src/ff.c **** 	}
1887:../../Extensions/fatfs//src/ff.c **** 	return sum;
1888:../../Extensions/fatfs//src/ff.c **** }
1889:../../Extensions/fatfs//src/ff.c **** 
1890:../../Extensions/fatfs//src/ff.c **** 
1891:../../Extensions/fatfs//src/ff.c **** 
1892:../../Extensions/fatfs//src/ff.c **** static
1893:../../Extensions/fatfs//src/ff.c **** WORD xname_sum (		/* Get check sum (to be used as hash) of the name */
1894:../../Extensions/fatfs//src/ff.c **** 	const WCHAR* name	/* File name to be calculated */
1895:../../Extensions/fatfs//src/ff.c **** )
1896:../../Extensions/fatfs//src/ff.c **** {
1897:../../Extensions/fatfs//src/ff.c **** 	WCHAR chr;
1898:../../Extensions/fatfs//src/ff.c **** 	WORD sum = 0;
1899:../../Extensions/fatfs//src/ff.c **** 
1900:../../Extensions/fatfs//src/ff.c **** 
1901:../../Extensions/fatfs//src/ff.c **** 	while ((chr = *name++) != 0) {
1902:../../Extensions/fatfs//src/ff.c **** 		chr = ff_wtoupper(chr);		/* File name needs to be ignored case */
1903:../../Extensions/fatfs//src/ff.c **** 		sum = ((sum & 1) ? 0x8000 : 0) + (sum >> 1) + (chr & 0xFF);
1904:../../Extensions/fatfs//src/ff.c **** 		sum = ((sum & 1) ? 0x8000 : 0) + (sum >> 1) + (chr >> 8);
1905:../../Extensions/fatfs//src/ff.c **** 	}
1906:../../Extensions/fatfs//src/ff.c **** 	return sum;
1907:../../Extensions/fatfs//src/ff.c **** }
1908:../../Extensions/fatfs//src/ff.c **** 
1909:../../Extensions/fatfs//src/ff.c **** 
1910:../../Extensions/fatfs//src/ff.c **** #if !_FS_READONLY && _USE_MKFS
1911:../../Extensions/fatfs//src/ff.c **** static
1912:../../Extensions/fatfs//src/ff.c **** DWORD xsum32 (
1913:../../Extensions/fatfs//src/ff.c **** 	BYTE  dat,	/* Data to be sumed */
1914:../../Extensions/fatfs//src/ff.c **** 	DWORD sum	/* Previous value */
1915:../../Extensions/fatfs//src/ff.c **** )
1916:../../Extensions/fatfs//src/ff.c **** {
1917:../../Extensions/fatfs//src/ff.c **** 	sum = ((sum & 1) ? 0x80000000 : 0) + (sum >> 1) + dat;
ARM GAS  /var/folders/cy/8kgpsxf90rz6cg1g85ws44fm0000gn/T//ccqN9xZo.s 			page 66


1918:../../Extensions/fatfs//src/ff.c **** 	return sum;
1919:../../Extensions/fatfs//src/ff.c **** }
