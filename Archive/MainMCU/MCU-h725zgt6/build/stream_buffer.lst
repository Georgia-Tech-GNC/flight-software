  48:Core/Inc/portmacro.h **** 
  49:Core/Inc/portmacro.h **** /* Type definitions. */
  50:Core/Inc/portmacro.h **** #define portCHAR          char
  51:Core/Inc/portmacro.h **** #define portFLOAT         float
  52:Core/Inc/portmacro.h **** #define portDOUBLE        double
  53:Core/Inc/portmacro.h **** #define portLONG          long
  54:Core/Inc/portmacro.h **** #define portSHORT         short
  55:Core/Inc/portmacro.h **** #define portSTACK_TYPE    uint32_t
  56:Core/Inc/portmacro.h **** #define portBASE_TYPE     long
  57:Core/Inc/portmacro.h **** 
  58:Core/Inc/portmacro.h **** typedef portSTACK_TYPE   StackType_t;
  59:Core/Inc/portmacro.h **** typedef long             BaseType_t;
  60:Core/Inc/portmacro.h **** typedef unsigned long    UBaseType_t;
  61:Core/Inc/portmacro.h **** 
  62:Core/Inc/portmacro.h **** #if ( configTICK_TYPE_WIDTH_IN_BITS == TICK_TYPE_WIDTH_16_BITS )
  63:Core/Inc/portmacro.h ****     typedef uint16_t     TickType_t;
  64:Core/Inc/portmacro.h ****     #define portMAX_DELAY              ( TickType_t ) 0xffff
  65:Core/Inc/portmacro.h **** #elif ( configTICK_TYPE_WIDTH_IN_BITS == TICK_TYPE_WIDTH_32_BITS )
  66:Core/Inc/portmacro.h ****     typedef uint32_t     TickType_t;
  67:Core/Inc/portmacro.h ****     #define portMAX_DELAY              ( TickType_t ) 0xffffffffUL
  68:Core/Inc/portmacro.h **** 
  69:Core/Inc/portmacro.h **** /* 32-bit tick type on a 32-bit architecture, so reads of the tick count do
  70:Core/Inc/portmacro.h ****  * not need to be guarded with a critical section. */
  71:Core/Inc/portmacro.h ****     #define portTICK_TYPE_IS_ATOMIC    1
  72:Core/Inc/portmacro.h **** #else
  73:Core/Inc/portmacro.h ****     #error configTICK_TYPE_WIDTH_IN_BITS set to unsupported tick type width.
  74:Core/Inc/portmacro.h **** #endif
  75:Core/Inc/portmacro.h **** /*-----------------------------------------------------------*/
  76:Core/Inc/portmacro.h **** 
  77:Core/Inc/portmacro.h **** /* Architecture specifics. */
  78:Core/Inc/portmacro.h **** #define portSTACK_GROWTH      ( -1 )
  79:Core/Inc/portmacro.h **** #define portTICK_PERIOD_MS    ( ( TickType_t ) 1000 / configTICK_RATE_HZ )
  80:Core/Inc/portmacro.h **** #define portBYTE_ALIGNMENT    8
  81:Core/Inc/portmacro.h **** #define portDONT_DISCARD      __attribute__( ( used ) )
  82:Core/Inc/portmacro.h **** /*-----------------------------------------------------------*/
  83:Core/Inc/portmacro.h **** 
  84:Core/Inc/portmacro.h **** /* Scheduler utilities. */
  85:Core/Inc/portmacro.h **** #define portYIELD()                                     \
  86:Core/Inc/portmacro.h ****     {                                                   \
  87:Core/Inc/portmacro.h ****         /* Set a PendSV to request a context switch. */ \
  88:Core/Inc/portmacro.h ****         portNVIC_INT_CTRL_REG = portNVIC_PENDSVSET_BIT; \
  89:Core/Inc/portmacro.h ****                                                         \
  90:Core/Inc/portmacro.h ****         /* Barriers are normally not required but do ensure the code is completely \
  91:Core/Inc/portmacro.h ****          * within the specified behaviour for the architecture. */ \
  92:Core/Inc/portmacro.h ****         __asm volatile ( "dsb" ::: "memory" );                     \
  93:Core/Inc/portmacro.h ****         __asm volatile ( "isb" );                                  \
  94:Core/Inc/portmacro.h ****     }
  95:Core/Inc/portmacro.h **** 
  96:Core/Inc/portmacro.h **** #define portNVIC_INT_CTRL_REG     ( *( ( volatile uint32_t * ) 0xe000ed04 ) )
  97:Core/Inc/portmacro.h **** #define portNVIC_PENDSVSET_BIT    ( 1UL << 28UL )
ARM GAS  /tmp/ccYJQfTI.s 			page 51


  98:Core/Inc/portmacro.h **** #define portEND_SWITCHING_ISR( xSwitchRequired ) \
  99:Core/Inc/portmacro.h ****     do                                           \
 100:Core/Inc/portmacro.h ****     {                                            \
 101:Core/Inc/portmacro.h ****         if( xSwitchRequired != pdFALSE )         \
 102:Core/Inc/portmacro.h ****         {                                        \
 103:Core/Inc/portmacro.h ****             traceISR_EXIT_TO_SCHEDULER();        \
 104:Core/Inc/portmacro.h ****             portYIELD();                         \
 105:Core/Inc/portmacro.h ****         }                                        \
 106:Core/Inc/portmacro.h ****         else                                     \
 107:Core/Inc/portmacro.h ****         {                                        \
 108:Core/Inc/portmacro.h ****             traceISR_EXIT();                     \
 109:Core/Inc/portmacro.h ****         }                                        \
 110:Core/Inc/portmacro.h ****     } while( 0 )
 111:Core/Inc/portmacro.h **** #define portYIELD_FROM_ISR( x )    portEND_SWITCHING_ISR( x )
