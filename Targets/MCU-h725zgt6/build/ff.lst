2865:../../Extensions/fatfs//src/ff.c **** 						res = FR_OK;
2866:../../Extensions/fatfs//src/ff.c **** 					} else {							/* Could not find the object */
2867:../../Extensions/fatfs//src/ff.c **** 						if (!(ns & NS_LAST)) res = FR_NO_PATH;	/* Adjust error code if not last segment */
2868:../../Extensions/fatfs//src/ff.c **** 					}
2869:../../Extensions/fatfs//src/ff.c **** 				}
2870:../../Extensions/fatfs//src/ff.c **** 				break;
2871:../../Extensions/fatfs//src/ff.c **** 			}
2872:../../Extensions/fatfs//src/ff.c **** 			if (ns & NS_LAST) break;			/* Last segment matched. Function completed. */
2873:../../Extensions/fatfs//src/ff.c **** 			/* Get into the sub-directory */
2874:../../Extensions/fatfs//src/ff.c **** 			if (!(obj->attr & AM_DIR)) {		/* It is not a sub-directory and cannot follow */
2875:../../Extensions/fatfs//src/ff.c **** 				res = FR_NO_PATH; break;
2876:../../Extensions/fatfs//src/ff.c **** 			}
2877:../../Extensions/fatfs//src/ff.c **** #if _FS_EXFAT
2878:../../Extensions/fatfs//src/ff.c **** 			if (fs->fs_type == FS_EXFAT) {		/* Save containing directory information for next dir */
2879:../../Extensions/fatfs//src/ff.c **** 				obj->c_scl = obj->sclust;
2880:../../Extensions/fatfs//src/ff.c **** 				obj->c_size = ((DWORD)obj->objsize & 0xFFFFFF00) | obj->stat;
2881:../../Extensions/fatfs//src/ff.c **** 				obj->c_ofs = dp->blk_ofs;
2882:../../Extensions/fatfs//src/ff.c **** 				obj->sclust = ld_dword(fs->dirbuf + XDIR_FstClus);	/* Open next directory */
2883:../../Extensions/fatfs//src/ff.c **** 				obj->stat = fs->dirbuf[XDIR_GenFlags] & 2;
2884:../../Extensions/fatfs//src/ff.c **** 				obj->objsize = ld_qword(fs->dirbuf + XDIR_FileSize);
2885:../../Extensions/fatfs//src/ff.c **** 			} else
2886:../../Extensions/fatfs//src/ff.c **** #endif
ARM GAS  /var/folders/cy/8kgpsxf90rz6cg1g85ws44fm0000gn/T//ccqN9xZo.s 			page 83


2887:../../Extensions/fatfs//src/ff.c **** 			{
2888:../../Extensions/fatfs//src/ff.c **** 				obj->sclust = ld_clust(fs, fs->win + dp->dptr % SS(fs));	/* Open next directory */
2889:../../Extensions/fatfs//src/ff.c **** 			}
2890:../../Extensions/fatfs//src/ff.c **** 		}
2891:../../Extensions/fatfs//src/ff.c **** 	}
2892:../../Extensions/fatfs//src/ff.c **** 
2893:../../Extensions/fatfs//src/ff.c **** 	return res;
2894:../../Extensions/fatfs//src/ff.c **** }
