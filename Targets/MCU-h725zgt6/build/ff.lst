1587:../../Extensions/fatfs//src/ff.c **** 
1588:../../Extensions/fatfs//src/ff.c **** static
1589:../../Extensions/fatfs//src/ff.c **** FRESULT dir_alloc (	/* FR_OK(0):succeeded, !=0:error */
1590:../../Extensions/fatfs//src/ff.c **** 	DIR* dp,		/* Pointer to the directory object */
1591:../../Extensions/fatfs//src/ff.c **** 	UINT nent		/* Number of contiguous entries to allocate */
1592:../../Extensions/fatfs//src/ff.c **** )
1593:../../Extensions/fatfs//src/ff.c **** {
1594:../../Extensions/fatfs//src/ff.c **** 	FRESULT res;
1595:../../Extensions/fatfs//src/ff.c **** 	UINT n;
1596:../../Extensions/fatfs//src/ff.c **** 	FATFS *fs = dp->obj.fs;
1597:../../Extensions/fatfs//src/ff.c **** 
1598:../../Extensions/fatfs//src/ff.c **** 
1599:../../Extensions/fatfs//src/ff.c **** 	res = dir_sdi(dp, 0);
1600:../../Extensions/fatfs//src/ff.c **** 	if (res == FR_OK) {
1601:../../Extensions/fatfs//src/ff.c **** 		n = 0;
1602:../../Extensions/fatfs//src/ff.c **** 		do {
1603:../../Extensions/fatfs//src/ff.c **** 			res = move_window(fs, dp->sect);
1604:../../Extensions/fatfs//src/ff.c **** 			if (res != FR_OK) break;
1605:../../Extensions/fatfs//src/ff.c **** #if _FS_EXFAT
1606:../../Extensions/fatfs//src/ff.c **** 			if ((fs->fs_type == FS_EXFAT) ? (int)((dp->dir[XDIR_Type] & 0x80) == 0) : (int)(dp->dir[DIR_Name
1607:../../Extensions/fatfs//src/ff.c **** #else
1608:../../Extensions/fatfs//src/ff.c **** 			if (dp->dir[DIR_Name] == DDEM || dp->dir[DIR_Name] == 0) {
1609:../../Extensions/fatfs//src/ff.c **** #endif
1610:../../Extensions/fatfs//src/ff.c **** 				if (++n == nent) break;	/* A block of contiguous free entries is found */
1611:../../Extensions/fatfs//src/ff.c **** 			} else {
1612:../../Extensions/fatfs//src/ff.c **** 				n = 0;					/* Not a blank entry. Restart to search */
1613:../../Extensions/fatfs//src/ff.c **** 			}
1614:../../Extensions/fatfs//src/ff.c **** 			res = dir_next(dp, 1);
1615:../../Extensions/fatfs//src/ff.c **** 		} while (res == FR_OK);	/* Next entry with table stretch enabled */
1616:../../Extensions/fatfs//src/ff.c **** 	}
1617:../../Extensions/fatfs//src/ff.c **** 
