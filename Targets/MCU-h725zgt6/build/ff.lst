4385:../../Extensions/fatfs//src/ff.c **** /* Get Number of Free Clusters                                           */
4386:../../Extensions/fatfs//src/ff.c **** /*-----------------------------------------------------------------------*/
4387:../../Extensions/fatfs//src/ff.c **** 
4388:../../Extensions/fatfs//src/ff.c **** FRESULT f_getfree (
4389:../../Extensions/fatfs//src/ff.c **** 	const TCHAR* path,	/* Path name of the logical drive number */
4390:../../Extensions/fatfs//src/ff.c **** 	DWORD* nclst,		/* Pointer to a variable to return number of free clusters */
4391:../../Extensions/fatfs//src/ff.c **** 	FATFS** fatfs		/* Pointer to return pointer to corresponding file system object */
4392:../../Extensions/fatfs//src/ff.c **** )
4393:../../Extensions/fatfs//src/ff.c **** {
4394:../../Extensions/fatfs//src/ff.c **** 	FRESULT res;
4395:../../Extensions/fatfs//src/ff.c **** 	FATFS *fs;
4396:../../Extensions/fatfs//src/ff.c **** 	DWORD nfree, clst, sect, stat;
4397:../../Extensions/fatfs//src/ff.c **** 	UINT i;
4398:../../Extensions/fatfs//src/ff.c **** 	BYTE *p;
4399:../../Extensions/fatfs//src/ff.c **** 	_FDID obj;
4400:../../Extensions/fatfs//src/ff.c **** 
4401:../../Extensions/fatfs//src/ff.c **** 
4402:../../Extensions/fatfs//src/ff.c **** 	/* Get logical drive */
4403:../../Extensions/fatfs//src/ff.c **** 	res = find_volume(&path, &fs, 0);
4404:../../Extensions/fatfs//src/ff.c **** 	if (res == FR_OK) {
4405:../../Extensions/fatfs//src/ff.c **** 		*fatfs = fs;				/* Return ptr to the fs object */
4406:../../Extensions/fatfs//src/ff.c **** 		/* If free_clst is valid, return it without full cluster scan */
4407:../../Extensions/fatfs//src/ff.c **** 		if (fs->free_clst <= fs->n_fatent - 2) {
4408:../../Extensions/fatfs//src/ff.c **** 			*nclst = fs->free_clst;
4409:../../Extensions/fatfs//src/ff.c **** 		} else {
4410:../../Extensions/fatfs//src/ff.c **** 			/* Get number of free clusters */
4411:../../Extensions/fatfs//src/ff.c **** 			nfree = 0;
4412:../../Extensions/fatfs//src/ff.c **** 			if (fs->fs_type == FS_FAT12) {	/* FAT12: Sector unalighed FAT entries */
4413:../../Extensions/fatfs//src/ff.c **** 				clst = 2; obj.fs = fs;
4414:../../Extensions/fatfs//src/ff.c **** 				do {
4415:../../Extensions/fatfs//src/ff.c **** 					stat = get_fat(&obj, clst);
4416:../../Extensions/fatfs//src/ff.c **** 					if (stat == 0xFFFFFFFF) { res = FR_DISK_ERR; break; }
ARM GAS  /var/folders/cy/8kgpsxf90rz6cg1g85ws44fm0000gn/T//ccqN9xZo.s 			page 112


4417:../../Extensions/fatfs//src/ff.c **** 					if (stat == 1) { res = FR_INT_ERR; break; }
4418:../../Extensions/fatfs//src/ff.c **** 					if (stat == 0) nfree++;
4419:../../Extensions/fatfs//src/ff.c **** 				} while (++clst < fs->n_fatent);
4420:../../Extensions/fatfs//src/ff.c **** 			} else {
4421:../../Extensions/fatfs//src/ff.c **** #if _FS_EXFAT
4422:../../Extensions/fatfs//src/ff.c **** 				if (fs->fs_type == FS_EXFAT) {	/* exFAT: Scan bitmap table */
4423:../../Extensions/fatfs//src/ff.c **** 					BYTE bm;
4424:../../Extensions/fatfs//src/ff.c **** 					UINT b;
4425:../../Extensions/fatfs//src/ff.c **** 
4426:../../Extensions/fatfs//src/ff.c **** 					clst = fs->n_fatent - 2;
4427:../../Extensions/fatfs//src/ff.c **** 					sect = fs->database;
4428:../../Extensions/fatfs//src/ff.c **** 					i = 0;
4429:../../Extensions/fatfs//src/ff.c **** 					do {
4430:../../Extensions/fatfs//src/ff.c **** 						if (i == 0 && (res = move_window(fs, sect++)) != FR_OK) break;
4431:../../Extensions/fatfs//src/ff.c **** 						for (b = 8, bm = fs->win[i]; b && clst; b--, clst--) {
4432:../../Extensions/fatfs//src/ff.c **** 							if (!(bm & 1)) nfree++;
4433:../../Extensions/fatfs//src/ff.c **** 							bm >>= 1;
4434:../../Extensions/fatfs//src/ff.c **** 						}
4435:../../Extensions/fatfs//src/ff.c **** 						i = (i + 1) % SS(fs);
4436:../../Extensions/fatfs//src/ff.c **** 					} while (clst);
4437:../../Extensions/fatfs//src/ff.c **** 				} else
4438:../../Extensions/fatfs//src/ff.c **** #endif
4439:../../Extensions/fatfs//src/ff.c **** 				{	/* FAT16/32: Sector alighed FAT entries */
4440:../../Extensions/fatfs//src/ff.c **** 					clst = fs->n_fatent; sect = fs->fatbase;
4441:../../Extensions/fatfs//src/ff.c **** 					i = 0; p = 0;
4442:../../Extensions/fatfs//src/ff.c **** 					do {
4443:../../Extensions/fatfs//src/ff.c **** 						if (i == 0) {
4444:../../Extensions/fatfs//src/ff.c **** 							res = move_window(fs, sect++);
4445:../../Extensions/fatfs//src/ff.c **** 							if (res != FR_OK) break;
4446:../../Extensions/fatfs//src/ff.c **** 							p = fs->win;
4447:../../Extensions/fatfs//src/ff.c **** 							i = SS(fs);
4448:../../Extensions/fatfs//src/ff.c **** 						}
4449:../../Extensions/fatfs//src/ff.c **** 						if (fs->fs_type == FS_FAT16) {
4450:../../Extensions/fatfs//src/ff.c **** 							if (ld_word(p) == 0) nfree++;
4451:../../Extensions/fatfs//src/ff.c **** 							p += 2; i -= 2;
4452:../../Extensions/fatfs//src/ff.c **** 						} else {
4453:../../Extensions/fatfs//src/ff.c **** 							if ((ld_dword(p) & 0x0FFFFFFF) == 0) nfree++;
4454:../../Extensions/fatfs//src/ff.c **** 							p += 4; i -= 4;
4455:../../Extensions/fatfs//src/ff.c **** 						}
4456:../../Extensions/fatfs//src/ff.c **** 					} while (--clst);
4457:../../Extensions/fatfs//src/ff.c **** 				}
4458:../../Extensions/fatfs//src/ff.c **** 			}
4459:../../Extensions/fatfs//src/ff.c **** 			*nclst = nfree;			/* Return the free clusters */
4460:../../Extensions/fatfs//src/ff.c **** 			fs->free_clst = nfree;	/* Now free_clst is valid */
4461:../../Extensions/fatfs//src/ff.c **** 			fs->fsi_flag |= 1;		/* FSInfo is to be updated */
4462:../../Extensions/fatfs//src/ff.c **** 		}
4463:../../Extensions/fatfs//src/ff.c **** 	}
4464:../../Extensions/fatfs//src/ff.c **** 
4465:../../Extensions/fatfs//src/ff.c **** 	LEAVE_FF(fs, res);
4466:../../Extensions/fatfs//src/ff.c **** }
4467:../../Extensions/fatfs//src/ff.c **** 
