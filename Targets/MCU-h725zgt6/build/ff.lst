3714:../../Extensions/fatfs//src/ff.c **** #else
3715:../../Extensions/fatfs//src/ff.c **** 		mem_cpy(fp->buf + fp->fptr % SS(fs), wbuff, wcnt);	/* Fit data to the sector */
3716:../../Extensions/fatfs//src/ff.c **** 		fp->flag |= FA_DIRTY;
3717:../../Extensions/fatfs//src/ff.c **** #endif
3718:../../Extensions/fatfs//src/ff.c **** 	}
3719:../../Extensions/fatfs//src/ff.c **** 
3720:../../Extensions/fatfs//src/ff.c **** 	fp->flag |= FA_MODIFIED;				/* Set file change flag */
