 265:../Core/Src/fatfs_sd.c **** 
 266:../Core/Src/fatfs_sd.c **** 	/* check disk type */
 267:../Core/Src/fatfs_sd.c **** 	type = 0;
 268:../Core/Src/fatfs_sd.c **** 
 269:../Core/Src/fatfs_sd.c **** 	/* send GO_IDLE_STATE command */
 270:../Core/Src/fatfs_sd.c **** 	if (SD_SendCmd(CMD0, 0) == 1)
 271:../Core/Src/fatfs_sd.c **** 	{
 272:../Core/Src/fatfs_sd.c **** 		/* timeout 1 sec */
 273:../Core/Src/fatfs_sd.c **** 		Timer1 = HAL_GetTick() + 1000;
ARM GAS  /tmp/ccV1y3Jk.s 			page 25


 274:../Core/Src/fatfs_sd.c **** 
 275:../Core/Src/fatfs_sd.c **** 		/* SDC V2+ accept CMD8 command, http://elm-chan.org/docs/mmc/mmc_e.html */
 276:../Core/Src/fatfs_sd.c **** 		if (SD_SendCmd(CMD8, 0x1AA) == 1)
 277:../Core/Src/fatfs_sd.c **** 		{
 278:../Core/Src/fatfs_sd.c **** 			/* operation condition register */
 279:../Core/Src/fatfs_sd.c **** 			for (n = 0; n < 4; n++)
 280:../Core/Src/fatfs_sd.c **** 			{
 281:../Core/Src/fatfs_sd.c **** 				ocr[n] = SPI_RxByte();
 282:../Core/Src/fatfs_sd.c **** 			}
 283:../Core/Src/fatfs_sd.c **** 
 284:../Core/Src/fatfs_sd.c **** 			/* voltage range 2.7-3.6V */
 285:../Core/Src/fatfs_sd.c **** 			if (ocr[2] == 0x01 && ocr[3] == 0xAA)
 286:../Core/Src/fatfs_sd.c **** 			{
 287:../Core/Src/fatfs_sd.c **** 				/* ACMD41 with HCS bit */
 288:../Core/Src/fatfs_sd.c **** 				do {
 289:../Core/Src/fatfs_sd.c **** 					if (SD_SendCmd(CMD55, 0) <= 1 && SD_SendCmd(CMD41, 1UL << 30) == 0) break;
 290:../Core/Src/fatfs_sd.c **** 				} while (HAL_GetTick() < Timer1);
 291:../Core/Src/fatfs_sd.c **** 
 292:../Core/Src/fatfs_sd.c **** 				/* READ_OCR */
 293:../Core/Src/fatfs_sd.c **** 				if (HAL_GetTick() < Timer1 && SD_SendCmd(CMD58, 0) == 0)
 294:../Core/Src/fatfs_sd.c **** 				{
 295:../Core/Src/fatfs_sd.c **** 					/* Check CCS bit */
 296:../Core/Src/fatfs_sd.c **** 					for (n = 0; n < 4; n++)
 297:../Core/Src/fatfs_sd.c **** 					{
 298:../Core/Src/fatfs_sd.c **** 						ocr[n] = SPI_RxByte();
 299:../Core/Src/fatfs_sd.c **** 					}
 300:../Core/Src/fatfs_sd.c **** 
 301:../Core/Src/fatfs_sd.c **** 					/* SDv2 (HC or SC) */
 302:../Core/Src/fatfs_sd.c **** 					type = (ocr[0] & 0x40) ? CT_SD2 | CT_BLOCK : CT_SD2;
 303:../Core/Src/fatfs_sd.c **** 				}
 304:../Core/Src/fatfs_sd.c **** 			}
 305:../Core/Src/fatfs_sd.c **** 		}
 306:../Core/Src/fatfs_sd.c **** 		else
 307:../Core/Src/fatfs_sd.c **** 		{
 308:../Core/Src/fatfs_sd.c **** 			/* SDC V1 or MMC */
 309:../Core/Src/fatfs_sd.c **** 			type = (SD_SendCmd(CMD55, 0) <= 1 && SD_SendCmd(CMD41, 0) <= 1) ? CT_SD1 : CT_MMC;
 310:../Core/Src/fatfs_sd.c **** 
 311:../Core/Src/fatfs_sd.c **** 			do
 312:../Core/Src/fatfs_sd.c **** 			{
 313:../Core/Src/fatfs_sd.c **** 				if (type == CT_SD1)
 314:../Core/Src/fatfs_sd.c **** 				{
 315:../Core/Src/fatfs_sd.c **** 					if (SD_SendCmd(CMD55, 0) <= 1 && SD_SendCmd(CMD41, 0) == 0) break; /* ACMD41 */
 316:../Core/Src/fatfs_sd.c **** 				}
 317:../Core/Src/fatfs_sd.c **** 				else
 318:../Core/Src/fatfs_sd.c **** 				{
 319:../Core/Src/fatfs_sd.c **** 					if (SD_SendCmd(CMD1, 0) == 0) break; /* CMD1 */
 320:../Core/Src/fatfs_sd.c **** 				}
 321:../Core/Src/fatfs_sd.c **** 
 322:../Core/Src/fatfs_sd.c **** 			} while (HAL_GetTick() < Timer1);
 323:../Core/Src/fatfs_sd.c **** 
 324:../Core/Src/fatfs_sd.c **** 			/* SET_BLOCKLEN */
 325:../Core/Src/fatfs_sd.c **** 			if (HAL_GetTick() >= Timer1 || SD_SendCmd(CMD16, 512) != 0) type = 0;
 326:../Core/Src/fatfs_sd.c **** 		}
 327:../Core/Src/fatfs_sd.c **** 	}
 328:../Core/Src/fatfs_sd.c **** 
 329:../Core/Src/fatfs_sd.c **** 	CardType = type;
 330:../Core/Src/fatfs_sd.c **** 
