2812:../../Extensions/fatfs//src/ff.c **** static
2813:../../Extensions/fatfs//src/ff.c **** FRESULT follow_path (	/* FR_OK(0): successful, !=0: error code */
2814:../../Extensions/fatfs//src/ff.c **** 	DIR* dp,			/* Directory object to return last directory and found object */
2815:../../Extensions/fatfs//src/ff.c **** 	const TCHAR* path	/* Full-path string to find a file or directory */
2816:../../Extensions/fatfs//src/ff.c **** )
2817:../../Extensions/fatfs//src/ff.c **** {
2818:../../Extensions/fatfs//src/ff.c **** 	FRESULT res;
2819:../../Extensions/fatfs//src/ff.c **** 	BYTE ns;
2820:../../Extensions/fatfs//src/ff.c **** 	_FDID *obj = &dp->obj;
2821:../../Extensions/fatfs//src/ff.c **** 	FATFS *fs = obj->fs;
2822:../../Extensions/fatfs//src/ff.c **** 
2823:../../Extensions/fatfs//src/ff.c **** 
2824:../../Extensions/fatfs//src/ff.c **** #if _FS_RPATH != 0
2825:../../Extensions/fatfs//src/ff.c **** 	if (*path != '/' && *path != '\\') {	/* Without heading separator */
2826:../../Extensions/fatfs//src/ff.c **** 		obj->sclust = fs->cdir;				/* Start from current directory */
2827:../../Extensions/fatfs//src/ff.c **** 	} else
2828:../../Extensions/fatfs//src/ff.c **** #endif
2829:../../Extensions/fatfs//src/ff.c **** 	{										/* With heading separator */
