1143:../../Extensions/fatfs//src/ff.c **** /*--------------------------------------*/
1144:../../Extensions/fatfs//src/ff.c **** 
1145:../../Extensions/fatfs//src/ff.c **** static
1146:../../Extensions/fatfs//src/ff.c **** DWORD find_bitmap (	/* 0:Not found, 2..:Cluster block found, 0xFFFFFFFF:Disk error */
1147:../../Extensions/fatfs//src/ff.c **** 	FATFS* fs,	/* File system object */
1148:../../Extensions/fatfs//src/ff.c **** 	DWORD clst,	/* Cluster number to scan from */
1149:../../Extensions/fatfs//src/ff.c **** 	DWORD ncl	/* Number of contiguous clusters to find (1..) */
1150:../../Extensions/fatfs//src/ff.c **** )
1151:../../Extensions/fatfs//src/ff.c **** {
1152:../../Extensions/fatfs//src/ff.c **** 	BYTE bm, bv;
1153:../../Extensions/fatfs//src/ff.c **** 	UINT i;
1154:../../Extensions/fatfs//src/ff.c **** 	DWORD val, scl, ctr;
1155:../../Extensions/fatfs//src/ff.c **** 
1156:../../Extensions/fatfs//src/ff.c **** 
1157:../../Extensions/fatfs//src/ff.c **** 	clst -= 2;	/* The first bit in the bitmap corresponds to cluster #2 */
1158:../../Extensions/fatfs//src/ff.c **** 	if (clst >= fs->n_fatent - 2) clst = 0;
1159:../../Extensions/fatfs//src/ff.c **** 	scl = val = clst; ctr = 0;
1160:../../Extensions/fatfs//src/ff.c **** 	for (;;) {
1161:../../Extensions/fatfs//src/ff.c **** 		if (move_window(fs, fs->database + val / 8 / SS(fs)) != FR_OK) return 0xFFFFFFFF;	/* (assuming bi
1162:../../Extensions/fatfs//src/ff.c **** 		i = val / 8 % SS(fs); bm = 1 << (val % 8);
1163:../../Extensions/fatfs//src/ff.c **** 		do {
1164:../../Extensions/fatfs//src/ff.c **** 			do {
1165:../../Extensions/fatfs//src/ff.c **** 				bv = fs->win[i] & bm; bm <<= 1;		/* Get bit value */
1166:../../Extensions/fatfs//src/ff.c **** 				if (++val >= fs->n_fatent - 2) {	/* Next cluster (with wrap-around) */
1167:../../Extensions/fatfs//src/ff.c **** 					val = 0; bm = 0; i = SS(fs);
1168:../../Extensions/fatfs//src/ff.c **** 				}
1169:../../Extensions/fatfs//src/ff.c **** 				if (!bv) {	/* Is it a free cluster? */
1170:../../Extensions/fatfs//src/ff.c **** 					if (++ctr == ncl) return scl + 2;	/* Check if run length is sufficient for required */
1171:../../Extensions/fatfs//src/ff.c **** 				} else {
1172:../../Extensions/fatfs//src/ff.c **** 					scl = val; ctr = 0;		/* Encountered a cluster in-use, restart to scan */
1173:../../Extensions/fatfs//src/ff.c **** 				}
1174:../../Extensions/fatfs//src/ff.c **** 				if (val == clst) return 0;	/* All cluster scanned? */
1175:../../Extensions/fatfs//src/ff.c **** 			} while (bm);
1176:../../Extensions/fatfs//src/ff.c **** 			bm = 1;
1177:../../Extensions/fatfs//src/ff.c **** 		} while (++i < SS(fs));
1178:../../Extensions/fatfs//src/ff.c **** 	}
1179:../../Extensions/fatfs//src/ff.c **** }
