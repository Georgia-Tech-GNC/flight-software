4536:../../Extensions/fatfs//src/ff.c **** 	DEF_NAMBUF
4537:../../Extensions/fatfs//src/ff.c **** 
4538:../../Extensions/fatfs//src/ff.c **** 
4539:../../Extensions/fatfs//src/ff.c **** 	/* Get logical drive */
4540:../../Extensions/fatfs//src/ff.c **** 	res = find_volume(&path, &fs, FA_WRITE);
4541:../../Extensions/fatfs//src/ff.c **** 	dj.obj.fs = fs;
4542:../../Extensions/fatfs//src/ff.c **** 	if (res == FR_OK) {
4543:../../Extensions/fatfs//src/ff.c **** 		INIT_NAMBUF(fs);
4544:../../Extensions/fatfs//src/ff.c **** 		res = follow_path(&dj, path);		/* Follow the file path */
4545:../../Extensions/fatfs//src/ff.c **** 		if (_FS_RPATH && res == FR_OK && (dj.fn[NSFLAG] & NS_DOT)) {
4546:../../Extensions/fatfs//src/ff.c **** 			res = FR_INVALID_NAME;			/* Cannot remove dot entry */
