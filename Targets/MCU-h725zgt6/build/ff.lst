1230:../../Extensions/fatfs//src/ff.c **** 	if (obj->stat == 3) {	/* Has the object been changed 'fragmented'? */
1231:../../Extensions/fatfs//src/ff.c **** 		for (cl = obj->sclust, n = obj->n_cont; n; cl++, n--) {	/* Create cluster chain on the FAT */
1232:../../Extensions/fatfs//src/ff.c **** 			res = put_fat(obj->fs, cl, cl + 1);
1233:../../Extensions/fatfs//src/ff.c **** 			if (res != FR_OK) return res;
1234:../../Extensions/fatfs//src/ff.c **** 		}
1235:../../Extensions/fatfs//src/ff.c **** 		obj->stat = 0;	/* Change status 'FAT chain is valid' */
1236:../../Extensions/fatfs//src/ff.c **** 	}
1237:../../Extensions/fatfs//src/ff.c **** 	return FR_OK;
1238:../../Extensions/fatfs//src/ff.c **** }
