ARM GAS  /var/folders/cy/8kgpsxf90rz6cg1g85ws44fm0000gn/T//ccqN9xZo.s 			page 33


 887:../../Extensions/fatfs//src/ff.c **** 	DWORD wsect;
 888:../../Extensions/fatfs//src/ff.c **** 	UINT nf;
 889:../../Extensions/fatfs//src/ff.c **** 	FRESULT res = FR_OK;
 890:../../Extensions/fatfs//src/ff.c **** 
 891:../../Extensions/fatfs//src/ff.c **** 
 892:../../Extensions/fatfs//src/ff.c **** 	if (fs->wflag) {	/* Write back the sector if it is dirty */
 893:../../Extensions/fatfs//src/ff.c **** 		wsect = fs->winsect;	/* Current sector number */
 894:../../Extensions/fatfs//src/ff.c **** 		if (disk_write(fs->drv, fs->win, wsect, 1) != RES_OK) {
 895:../../Extensions/fatfs//src/ff.c **** 			res = FR_DISK_ERR;
 896:../../Extensions/fatfs//src/ff.c **** 		} else {
 897:../../Extensions/fatfs//src/ff.c **** 			fs->wflag = 0;
 898:../../Extensions/fatfs//src/ff.c **** 			if (wsect - fs->fatbase < fs->fsize) {		/* Is it in the FAT area? */
 899:../../Extensions/fatfs//src/ff.c **** 				for (nf = fs->n_fats; nf >= 2; nf--) {	/* Reflect the change to all FAT copies */
 900:../../Extensions/fatfs//src/ff.c **** 					wsect += fs->fsize;
 901:../../Extensions/fatfs//src/ff.c **** 					disk_write(fs->drv, fs->win, wsect, 1);
 902:../../Extensions/fatfs//src/ff.c **** 				}
 903:../../Extensions/fatfs//src/ff.c **** 			}
 904:../../Extensions/fatfs//src/ff.c **** 		}
 905:../../Extensions/fatfs//src/ff.c **** 	}
 906:../../Extensions/fatfs//src/ff.c **** 	return res;
 907:../../Extensions/fatfs//src/ff.c **** }
 908:../../Extensions/fatfs//src/ff.c **** #endif
